---
import TestimonialCard from '../ui/TestimonialCard.astro';

// 保持头像引用
import testimonial1Img from '@assets/photo-1494790108377-be9c29b29330.jpg';
import testimonial2Img from '@assets/photo-1507003211169-0a1dd7228f2d.jpg';
import testimonial3Img from '@assets/photo-1438761681033-6461ffad8d80.jpg';

const testimonials = [
  {
    quote: "The IE5 ultra-high efficiency motors from Hejun have significantly reduced our energy costs. Their technical support during the heavy-duty installation phase was exceptional and professional.",
    name: "Robert Müller",
    role: "Technical Director, German Kraft Paper Solutions",
    image: testimonial1Img,
    ringColor: "ring-blue-600"
  },
  {
    quote: "Exceptional durability on the tungsten carbide corrugating rolls. The precision in high-speed operation is remarkable, effectively increasing our overall plant output by 15%.",
    name: "Arjun Mehta",
    role: "Operations Manager, Apex Packaging Group",
    image: testimonial2Img,
    ringColor: "ring-emerald-600"
  },
  {
    quote: "We've been sourcing motors from Hejun for three years. Their reliability in harsh industrial environments is unmatched. A truly dependable partner for long-term manufacturing.",
    name: "Sarah Jenkins",
    role: "Lead Engineer, Nordic Automation Ltd",
    image: testimonial3Img,
    ringColor: "ring-blue-600"
  }
];
---

<section class="py-24 bg-slate-50">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="inline-block px-4 py-2 mb-4 bg-[#012D46] text-white text-[10px] font-black rounded-full uppercase tracking-widest">
        Global Partnership
      </div>
      <h2 class="text-4xl md:text-5xl font-black text-slate-900 mb-6 uppercase italic">
        Trusted by <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-emerald-600">Industry Leaders</span>
      </h2>
      <p class="text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed italic border-l-4 border-blue-600 pl-6 inline-block text-left">
        Real-world feedback from global partners utilizing Hejun's high-performance motor systems and precision industrial machinery.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {testimonials.map((testimonial) => (
        <TestimonialCard testimonial={testimonial} variant="home" />
      ))}
    </div>
    
    <div class="mt-16 pt-8 border-t border-slate-200 flex flex-wrap justify-center gap-12 opacity-30 grayscale">
       <span class="text-xl font-black italic uppercase tracking-tighter">ISO 9001:2015</span>
       <span class="text-xl font-black italic uppercase tracking-tighter">CE Certified</span>
       <span class="text-xl font-black italic uppercase tracking-tighter">IE5 Energy Standard</span>
       <span class="text-xl font-black italic uppercase tracking-tighter">Heavy Duty Quality</span>
    </div>
  </div>
</section>