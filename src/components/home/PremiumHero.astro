---
import Button from '../ui/Button.astro';
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<section class="relative overflow-hidden bg-neutral-900 text-white">
  <div class="swiper heroSwiper w-full h-[80vh]">
    <div class="swiper-wrapper">
      
      <div class="swiper-slide relative flex items-center justify-center">
        <img src="/image/banner1.webp" class="absolute inset-0 w-full h-full object-cover" alt="HEJUN MOTORS Banner" />
        
        <div class="absolute inset-0 bg-black/40 z-10"></div>
        
        <div class="container mx-auto relative z-20 h-full flex items-center px-6 lg:px-16">
          <div class="max-w-4xl space-y-6">
            <h1 class="text-5xl md:text-7xl font-bold leading-tight animate-fadeInUp">
              Precision Motion <br/>
              <span class="text-secondary-400">Solutions Architect</span>
            </h1>
            <p class="text-xl md:text-2xl text-neutral-200 max-w-2xl animate-fadeInUp" style="animation-delay: 0.2s">
              We integrate advanced motor technology with industrial intelligence, driving efficiency across global production lines.
            </p>
            <div class="flex gap-4 pt-4 animate-fadeInUp" style="animation-delay: 0.4s">
              <Button href="/rfq" size="lg" variant="secondary" class="font-bold">Request Quote</Button>
              <Button href="/motor" size="lg" variant="outline" class="text-white! border-white! hover:bg-white/10!">View Products</Button>
            </div>
          </div>
        </div>
      </div>

    </div>
    <div class="swiper-pagination"></div>
  </div>
</section>

<script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script is:inline>
  // 使用这种方式确保在 Astro 环境下脚本能正常运行
  document.addEventListener('DOMContentLoaded', () => {
    new Swiper(".heroSwiper", {
      loop: true,
      autoplay: { 
        delay: 5000,
        disableOnInteraction: false 
      },
      pagination: { 
        el: ".swiper-pagination", 
        clickable: true 
      },
      effect: 'fade',
      fadeEffect: { crossFade: true },
      speed: 1000,
    });
  });
</script>

<style>
  /* 轮播图圆点颜色设为你的辅助金黄色 */
  :root { --swiper-theme-color: #F8BB1B; }
  .swiper-pagination-bullet { background: white; opacity: 0.5; }
  .swiper-pagination-bullet-active { opacity: 1; }
  
  /* 基础动画 */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fadeInUp {
    animation: fadeInUp 0.8s ease-out forwards;
  }
</style>