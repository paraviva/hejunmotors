---
import { Image } from 'astro:assets';
// 建议保留这个或换成一张电机控制台/生产线的工业图
import techDashboardImg from '@assets/photo-1551288049-bebda4e38f71.jpg';

interface Technology {
  title: string;
  description: string;
  iconGradient: string;
  iconPath: string;
}

const technologies: Technology[] = [
  {
    title: "IE5 Ultra-High Efficiency",
    description: "Our motors meet and exceed IE5 standards, significantly reducing energy consumption and operational costs for heavy industrial applications.",
    iconGradient: "from-blue-600 to-blue-700",
    iconPath: "M13 10V3L4 14h7v7l9-11h-7z" // 闪电图标
  },
  {
    title: "Advanced Vector Control",
    description: "Digital precision control systems designed for paper machinery, ensuring stable torque and synchronization across complex production lines.",
    iconGradient: "from-teal-600 to-teal-700",
    iconPath: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" // 柱状图/控制感图标
  },
  {
    title: "Smart Monitoring IoT",
    description: "Integrated sensors provide real-time feedback on vibration, temperature, and load, preventing downtime through predictive maintenance.",
    iconGradient: "from-blue-600 to-blue-700",
    iconPath: "M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" // 设备/手机端图标
  },
  {
    title: "Heavy-Duty Engineering",
    description: "Structural designs reinforced for harsh environments, featuring superior insulation and heat dissipation for 24/7 continuous operation.",
    iconGradient: "from-teal-600 to-teal-700",
    iconPath: "M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" // 锁定/安全感图标
  }
];
---

<section class="py-24 bg-linear-to-b from-slate-900 via-slate-800 to-slate-900 relative overflow-hidden">
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <div class="inline-block px-4 py-2 mb-4 bg-white/10 backdrop-blur-sm text-white text-sm font-semibold rounded-full">
          Technology & Innovation
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-6 uppercase italic">
          Powered by <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-400 to-teal-400">Precision Drive Tech</span>
        </h2>
        <p class="text-xl text-slate-300 mb-8 leading-relaxed italic border-l-2 border-blue-500 pl-4">
          Hejun Motors combines IE5 efficiency, vector control, and IoT monitoring to deliver intelligent industrial drive solutions that optimize performance in real-time.
        </p>

        <div class="space-y-6">
          {technologies.map((tech) => (
            <div class="flex items-start group">
              <div class={`shrink-0 w-12 h-12 rounded-lg bg-linear-to-br ${tech.iconGradient} flex items-center justify-center mr-4 group-hover:scale-110 transition-transform shadow-lg`}>
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={tech.iconPath} />
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-white mb-2 uppercase tracking-tight">{tech.title}</h3>
                <p class="text-slate-400 leading-relaxed text-sm italic">
                  {tech.description}
                </p>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-10">
          <a 
            href="/rfq" 
            class="inline-flex items-center px-6 py-3 text-sm font-black text-white bg-linear-to-r from-blue-600 to-teal-600 hover:from-blue-700 hover:to-teal-700 rounded-sm shadow-lg hover:shadow-xl transition-all group uppercase tracking-widest"
          >
            Request Technical Data
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>

      <div class="relative">
        <div class="relative rounded-2xl overflow-hidden shadow-2xl border border-white/5">
          <Image 
            src={techDashboardImg}
            alt="Advanced motor control and diagnostics interface"
            class="w-full h-full object-cover"
            width={1200}
            height={800}
          />
          <div class="absolute inset-0 bg-linear-to-br from-blue-900/80 via-teal-900/60 to-blue-900/80"></div>
          <div class="absolute inset-0 flex items-center justify-center p-8">
            <div class="text-center">
              <div class="w-24 h-24 mx-auto mb-6 rounded-full bg-linear-to-br from-blue-500 to-teal-500 flex items-center justify-center shadow-2xl animate-pulse">
                <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <h3 class="text-2xl font-black text-white mb-2 uppercase italic">Hejun Drive Tech</h3>
              <p class="text-slate-300 text-sm tracking-widest uppercase font-bold">Smart Diagnostics Platform</p>
            </div>
          </div>
        </div>
        
        <div class="absolute -top-4 -right-4 bg-slate-900 border border-blue-500/30 rounded-lg p-4 shadow-xl z-20">
          <div class="flex items-center">
            <div class="w-3 h-3 rounded-full bg-green-500 mr-2 animate-ping"></div>
            <span class="text-xs font-black text-white uppercase tracking-tighter">IE5 Efficiency Pass</span>
          </div>
        </div>
        <div class="absolute -bottom-4 -left-4 bg-slate-900 border border-teal-500/30 rounded-lg p-4 shadow-xl z-20">
          <div class="flex items-center">
            <div class="w-3 h-3 rounded-full bg-blue-500 mr-2"></div>
            <span class="text-xs font-black text-white uppercase tracking-tighter">Real-time Torque Sync</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>