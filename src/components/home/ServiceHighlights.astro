---
import FeatureShowcase from '../react/FeatureShowcase';
---

<section class="py-24 bg-slate-50">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
        Why Choose <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-600 to-teal-600">Hejun Motors</span>
      </h2>
      <p class="text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed">
        Cutting-edge technology to the highest quality. We integrate advanced motor technology with industrial intelligence.
      </p>
    </div>

    <FeatureShowcase client:load />
    
    </div>
</section>