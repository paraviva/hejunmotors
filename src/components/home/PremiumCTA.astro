---
import { Image } from 'astro:assets';
// 建议复用你项目里那张高质量的工业背景图
import industrialBgImg from '@assets/photo-1558618666-fcd25c85cd64.jpg';
import { ArrowRight, ShieldCheck, Globe2, Clock, Award } from 'lucide-react';
---

<section class="relative py-32 overflow-hidden">
  <div class="absolute inset-0">
    <Image 
      src={industrialBgImg}
      alt="Modern industrial manufacturing"
      class="w-full h-full object-cover"
      width={2070}
      height={1380}
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[#012D46]/95 to-blue-900/90"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-4xl mx-auto text-center text-white">
      <div class="inline-block px-4 py-2 mb-6 bg-blue-500/20 backdrop-blur-md text-blue-300 text-xs font-black rounded-full border border-blue-500/30 uppercase tracking-widest">
        Get Started Today
      </div>
      
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-black mb-6 leading-[1.1] uppercase italic">
        Ready to Optimize with <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400">Hejun Motors</span>?
      </h2>
      
      <p class="text-lg md:text-xl text-slate-300 mb-12 max-w-2xl mx-auto leading-relaxed italic border-l-2 border-blue-500 px-6">
        Partner with industry experts. Get a high-efficiency motor & paper machinery solution designed for your global success and accelerate your industrial growth.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-6 justify-center mb-16">
        <a 
          href="/rfq"
          class="inline-flex items-center justify-center px-10 py-4 text-sm font-black text-[#012D46] bg-white hover:bg-blue-500 hover:text-white rounded-sm shadow-2xl transition-all group uppercase tracking-widest"
        >
          Request a Quote
          <ArrowRight class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" />
        </a>
        <a 
          href="/cases"
          class="inline-flex items-center justify-center px-10 py-4 text-sm font-black text-white border-2 border-white/30 hover:bg-white/10 rounded-sm backdrop-blur-sm transition-all group uppercase tracking-widest"
        >
          View Our Projects
          <ArrowRight class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" />
        </a>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto">
        <div class="backdrop-blur-md bg-white/5 rounded-2xl p-6 border border-white/10 group hover:bg-white/10 transition-all">
          <Award class="w-6 h-6 mb-3 text-blue-400 mx-auto" />
          <div class="text-2xl font-black mb-1 italic">20+</div>
          <div class="text-[10px] text-slate-400 uppercase tracking-widest font-bold group-hover:text-blue-300">Years Experience</div>
        </div>
        
        <div class="backdrop-blur-md bg-white/5 rounded-2xl p-6 border border-white/10 group hover:bg-white/10 transition-all">
          <ShieldCheck class="w-6 h-6 mb-3 text-blue-400 mx-auto" />
          <div class="text-2xl font-black mb-1 italic">ISO 9001</div>
          <div class="text-[10px] text-slate-400 uppercase tracking-widest font-bold group-hover:text-blue-300">Certified</div>
        </div>
        
        <div class="backdrop-blur-md bg-white/5 rounded-2xl p-6 border border-white/10 group hover:bg-white/10 transition-all">
          <Clock class="w-6 h-6 mb-3 text-blue-400 mx-auto" />
          <div class="text-2xl font-black mb-1 italic">24/7</div>
          <div class="text-[10px] text-slate-400 uppercase tracking-widest font-bold group-hover:text-blue-300">Expert Support</div>
        </div>
        
        <div class="backdrop-blur-md bg-white/5 rounded-2xl p-6 border border-white/10 group hover:bg-white/10 transition-all">
          <Globe2 class="w-6 h-6 mb-3 text-blue-400 mx-auto" />
          <div class="text-2xl font-black mb-1 italic">Global</div>
          <div class="text-[10px] text-slate-400 uppercase tracking-widest font-bold group-hover:text-blue-300">Service Network</div>
        </div>
      </div>
    </div>
  </div>
</section>