---
import { ClipboardCheck, ShieldAlert, Settings2, Ship, HardHat, LifeBuoy, ArrowRight } from 'lucide-react';

const steps = [
  {
    phase: "01",
    title: "Requirement Confirmation",
    description: "Technical specification analysis (Motor parameters or paper machine capacity) and preliminary proposal submission.",
    icon: ClipboardCheck,
  },
  {
    phase: "02",
    title: "Agreement & Validation",
    description: "In-depth technical validation to confirm all standards, followed by formal contract execution.",
    icon: ShieldAlert,
  },
  {
    phase: "03",
    title: "Production & QA",
    description: "Motor production scheduling or detailed paper machine design. All units undergo Factory Acceptance Testing (FAT).",
    icon: Settings2,
  },
  {
    phase: "04",
    title: "Global Logistics",
    description: "Flexible FOB/EXW coordination with a full set of customs documentation (Invoice, Packing List, CO).",
    icon: Ship,
  },
  {
    phase: "05",
    title: "On-site Installation",
    description: "Provision of detailed installation guides or dispatch of engineers for on-site setup and operator training.",
    icon: HardHat,
  },
  {
    phase: "06",
    title: "Warranty & Support",
    description: "Final acceptance signing to activate warranty, followed by ongoing spare parts supply and maintenance.",
    icon: LifeBuoy,
  }
];
---

<section class="py-24 bg-white relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.05]">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, #012D46 1px, transparent 0); background-size: 40px 40px;"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-3xl mb-20">
      <div class="inline-block px-4 py-2 mb-4 bg-slate-100 text-[#012D46] text-[10px] font-black rounded-full uppercase tracking-widest">
        Procurement Logic
      </div>
      <h2 class="text-4xl md:text-5xl font-black text-slate-900 mb-6 uppercase italic leading-none">
        Our Execution <span class="text-blue-600">Workflow</span>
      </h2>
      <p class="text-xl text-slate-500 leading-relaxed italic border-l-4 border-blue-600 pl-6">
        A standardized technical workflow ensuring precision and global trade compliance.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-16">
      {steps.map((step) => (
        <div class="group relative">
          <div class="absolute -top-8 -left-4 text-8xl font-black text-slate-50 group-hover:text-blue-50 transition-colors duration-500 italic -z-10">
            {step.phase}
          </div>
          
          <div class="flex flex-col items-start">
            <div class="w-14 h-14 rounded-xl bg-slate-900 text-white flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:scale-110 transition-all duration-500 shadow-xl shadow-slate-200">
              <step.icon size={28} />
            </div>
            
            <h3 class="text-2xl font-black text-slate-900 uppercase tracking-tight mb-4 group-hover:text-blue-600 transition-colors">
              {step.title}
            </h3>
            
            <p class="text-slate-500 leading-relaxed text-base italic">
              {step.description}
            </p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-20 pt-10 border-t border-slate-100 flex justify-start">
      <a 
        href="/rfq" 
        class="inline-flex items-center px-8 py-3 text-[10px] font-black text-white bg-slate-900 hover:bg-blue-600 rounded-sm shadow-lg transition-all group uppercase tracking-[0.2em]"
      >
        Start Project
        <ArrowRight size={14} className="ml-2 group-hover:translate-x-1 transition-transform" />
      </a>
    </div>
  </div>
</section>