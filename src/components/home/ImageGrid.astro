---
import ImageReveal from '@components/react/ImageReveal';
import { Image } from 'astro:assets';

// 1. 导入你找到的这张图片
import tempProductImg from '@assets/Efficiency-by-Design.webp';

const products = [
  // --- 前3个：电机系列 (统一使用 tempProductImg) ---
  {
    model: "YX2 Series",
    title: "High Voltage Motors",
    img: tempProductImg,
    delay: 0
  },
  {
    model: "YEJ Series",
    title: "Italian Style Brake Motors",
    img: tempProductImg,
    delay: 0.1
  },
  {
    model: "YE5 Series",
    title: "High-Efficiency Motors",
    img: tempProductImg,
    delay: 0.2
  },
  // --- 后3个：造纸机械系列 (统一使用 tempProductImg) ---
  {
    model: "Specialized",
    title: "Special Paper Machine",
    img: tempProductImg,
    delay: 0.3
  },
  {
    model: "Coated Line",
    title: "Paper Coated Whiteboard Machine",
    img: tempProductImg,
    delay: 0.4
  },
  {
    model: "Krafts System",
    title: "Cylinder Mold Kraft Paper Machine",
    img: tempProductImg,
    delay: 0.5
  }
];
---

<section class="py-24 bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="mb-16 border-l-4 border-blue-600 pl-6">
      <h2 class="text-4xl md:text-5xl font-black text-slate-900 uppercase italic tracking-tighter leading-none">
        Featured <span class="text-blue-600">Products</span>
      </h2>
      <p class="text-slate-500 mt-2 font-bold uppercase tracking-widest text-xs border-b-2 border-slate-50 pb-2">
        Hejun Motors & Paper Machinery Solutions
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
      {products.map((product) => (
        <ImageReveal client:load delay={product.delay}>
          <div class="group bg-white rounded-sm border border-slate-100 overflow-hidden hover:shadow-2xl transition-all duration-500">
            <div class="relative h-72 overflow-hidden bg-slate-50 border-b border-slate-100">
              <Image 
                src={product.img}
                alt={product.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 grayscale-[50%] group-hover:grayscale-0"
                width={800}
                height={600}
              />
            </div>

            <div class="p-8">
              <div class="text-[10px] font-black text-blue-600 uppercase tracking-widest mb-1">
                {product.model}
              </div>
              <h3 class="text-xl font-black text-slate-900 uppercase italic mb-6 leading-tight min-h-[3rem]">
                {product.title}
              </h3>
              
              <div class="pt-4 border-t border-slate-100">
                <a href="/products" class="inline-flex items-center text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 group-hover:text-blue-600 transition-colors">
                  View More
                  <svg class="w-3 h-3 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </ImageReveal>
      ))}
    </div>

  </div>
</section>