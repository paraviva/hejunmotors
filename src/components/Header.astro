---
import MobileMenu from '@components/react/MobileMenu';
import { Mail, Phone, Facebook, Linkedin, Twitter, Instagram, ChevronDown } from 'lucide-react';

const { currentPathname } = Astro.props;
const isActiveLink = (href: string) : boolean => { 
  if (href === '/' && currentPathname === '/') return true;
  if (href !== '/' && currentPathname?.startsWith(href)) return true;
  return false;
}

const menuConfig = [
  { name: 'HOME', href: '/' },
  { name: 'ABOUT US', href: '/about' },
  { 
    name: 'MOTOR', 
    href: '/motor',
    children: [
      { name: 'high-efficiency motor', href: '/products/high-efficiency-motor' },
      { name: 'vector reluctance motor', href: '/products/vector-reluctance-motor' }
    ]
  },
  { 
    name: 'PAPER MACHINE', 
    href: '/paper-machine',
    children: [
      { name: 'paper machine', href: '/products/paper-machine' },
      { name: 'corrugating roll', href: '/products/corrugating-roll' }
    ]
  },
  { name: 'NEWS', href: '/news' },
  { 
    name: 'CASE', 
    href: '/cases',
    children: [
      { name: 'motor projects', href: '/cases/motor' },
      { name: 'paper machine projects', href: '/cases/paper-machine' },
      { name: 'rollers projects', href: '/cases/rollers' },
      { name: 'vector reluctance motor projects', href: '/cases/vector' }
    ]
  },
  { 
    name: 'FAQ', 
    href: '/faq',
    children: [
      { name: 'motor products', href: '/faq/motor' },
      { name: 'paper machine products', href: '/faq/paper-machine' },
      { name: 'general service & procurement', href: '/faq/service' }
    ]
  },
  { name: 'CONTACT', href: '/contact' }
];
---

<header class="w-full shadow-md font-sans bg-white border-b border-slate-100">
  <div class="bg-[#012D46] text-white py-2 px-4 sm:px-6 lg:px-8 border-b border-white/5 hidden md:block">
    <div class="container mx-auto flex justify-between items-center text-xs md:text-[13px]">
      <div class="italic text-slate-300">
        Welcome to <strong>Hangzhou Hejun Electromechanical Technology Co., Ltd.</strong>
      </div>
      <div class="flex items-center gap-5 border-l border-white/20 pl-5 text-slate-300">
        <a href="#" class="hover:text-white transition-all"><Facebook className="w-4 h-4" /></a>
        <a href="#" class="hover:text-blue-200 transition-all"><Linkedin className="w-4 h-4" /></a>
        <a href="#" class="hover:text-blue-200 transition-all"><Twitter className="w-4 h-4" /></a>
        <a href="#" class="hover:text-blue-200 transition-all"><Instagram className="w-4 h-4" /></a>
      </div>
    </div>
  </div>

  <div class="py-3 px-4 sm:px-6 lg:px-8 border-b border-slate-50">
    <div class="container mx-auto flex items-center justify-between">
      <a href="/" class="flex-shrink-0">
        <img src="/image/hejunlogo.webp" alt="Hejun Logo" class="h-16 w-auto" />
      </a>

      <div class="hidden lg:flex items-center gap-10 border-l border-slate-100 pl-10 ml-10">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-slate-50 border border-slate-100 rounded-lg flex items-center justify-center text-[#012D46]">
            <Mail className="w-5 h-5" />
          </div>
          <div class="flex flex-col">
            <span class="text-[9px] uppercase tracking-wider text-slate-400 font-bold leading-tight">Email Us</span>
            <a href="mailto:sales@convrmotor.com" class="text-[14px] font-bold text-slate-900">sales@convrmotor.com</a>
          </div>
        </div>

        <div class="flex items-center gap-3 border-l border-slate-100 pl-10">
          <div class="w-10 h-10 bg-slate-50 border border-slate-100 rounded-lg flex items-center justify-center text-[#012D46]">
            <Phone className="w-5 h-5" />
          </div>
          <div class="flex flex-col">
            <span class="text-[9px] uppercase tracking-wider text-slate-400 font-bold leading-tight">Call Us</span>
            <a href="tel:+8615257432470" class="text-[14px] font-bold text-slate-900">+86 152 5743 2470</a>
          </div>
        </div>

        <div class="flex items-center gap-3 border-l border-slate-100 pl-10">
          <div class="w-10 h-10 bg-slate-50 border border-slate-100 rounded-lg flex items-center justify-center text-[#012D46]">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <div class="flex flex-col">
            <span class="text-[9px] uppercase tracking-wider text-slate-400 font-bold leading-tight">Whatsapp</span>
            <a href="https://wa.me/8615257432470" target="_blank" class="text-[14px] font-bold text-slate-900 hover:text-blue-600">+86 152 5743 2470</a>
          </div>
        </div>
      </div>

      <a href="/rfq" class="hidden sm:inline-flex items-center px-9 py-3.5 text-[15px] font-bold text-white bg-[#012D46] hover:bg-[#001f30] rounded shadow-md transition-all uppercase tracking-wider flex-shrink-0">Request Quote</a>
    </div>
  </div>

  <div class="bg-white border-b border-slate-200 sticky top-0 z-50 hidden md:block">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <ul class="flex items-center justify-between min-w-full">
        {menuConfig.map((item) => {
          const active = isActiveLink(item.href);
          return (
            <li class="relative group">
              <a
                href={item.href}
                class={`py-5 text-[17px] font-bold flex items-center gap-1.5 transition-all tracking-normal whitespace-nowrap uppercase ${active ? 'text-[#012D46]' : 'text-slate-900 hover:text-[#012D46]'}`}
              >
                {item.name}
                {item.children && <ChevronDown className="w-4 h-4 opacity-40 group-hover:rotate-180 transition-transform" />}
              </a>

              {item.children && (
                <div class="absolute top-full left-0 w-68 bg-white shadow-2xl border border-slate-100 py-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-0 z-50">
                  {item.children.map((sub) => (
                    <a href={sub.href} class="block px-8 py-3.5 text-[15px] font-medium text-slate-600 hover:text-white hover:bg-[#012D46] transition-all capitalize">
                      {sub.name}
                    </a>
                  ))}
                </div>
              )}
            </li>
          );
        })}
      </ul>
    </div>
  </div>
</header>