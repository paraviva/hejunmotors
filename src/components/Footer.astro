---
import { NAVIGATION, SOCIAL_LINKS, SITE } from '@config/site';
import { Linkedin, Mail, Phone, MapPin, ArrowUp } from 'lucide-react';

const FOOTER_SITEMAP = [
  { name: 'HOME', href: '/' },
  { name: 'ABOUT US', href: '/about' },
  { name: 'MOTOR', href: '/products' },
  { name: 'PAPER MACHINE', href: '/products' },
  { name: 'NEWS', href: '/blog' },
  { name: 'CASE', href: '/projects' },
  { name: 'FAQ', href: '/faq' },
  { name: 'CONTACT', href: '/contact' }
];

const SOLUTIONS = [
  { name: 'IE5 PM Motors', href: '/rfq' },
  { name: 'Paper Machine Drives', href: '/rfq' },
  { name: 'Explosion-proof Motors', href: '/rfq' },
  { name: 'Custom OEM Design', href: '/rfq' }
];
---

<footer class="bg-slate-900 text-slate-300 border-t border-slate-800 font-sans relative">
  <div class="container mx-auto px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-4">
      <div class="lg:col-span-1 space-y-6">
        <a href="/" class="block group">
          <img 
            src="/image/hejunlogo.webp" 
            alt="Hejun Electromechanical Logo" 
            class="h-14 w-auto mb-4 brightness-110 transition-all duration-300"
          />
          <span class="text-xl font-bold text-white leading-tight tracking-tight block">
            Hejun Electromechanical <br/> Technology Co., Ltd.
          </span>
        </a>
        <p class="text-base text-slate-400 leading-relaxed max-w-xs">
          Professional manufacturer of IE5 ultra-premium efficiency motors and customized paper machinery solutions. 
        </p>
        <div class="flex space-x-4">
          <a
            href={SOCIAL_LINKS.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 flex items-center justify-center rounded-lg bg-slate-800 text-slate-400 hover:bg-blue-600 hover:text-white transition-all duration-300"
          >
            <Linkedin className="w-5 h-5" />
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-6 border-l-4 border-blue-500 pl-3">
          Sitemap
        </h3>
        <ul class="grid grid-cols-1 gap-y-3">
          {FOOTER_SITEMAP.map((link) => (
            <li>
              <a href={link.href} class="text-base text-slate-400 hover:text-blue-400 transition-colors flex items-center group uppercase font-medium">
                <span class="w-0 group-hover:w-2 h-px bg-blue-400 transition-all mr-0 group-hover:mr-2"></span>
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-6 border-l-4 border-blue-500 pl-3">
          Solutions
        </h3>
        <ul class="space-y-3">
          {SOLUTIONS.map((item) => (
            <li>
              <a href={item.href} class="text-base text-slate-400 hover:text-blue-400 transition-colors flex items-center group font-medium">
                <span class="w-0 group-hover:w-2 h-px bg-blue-400 transition-all mr-0 group-hover:mr-2"></span>
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-6 border-l-4 border-slate-500 pl-3">
          Contact Details
        </h3>
        <ul class="space-y-4 text-base">
          <li class="flex items-center space-x-3 text-slate-400">
            <Mail className="w-5 h-5 text-blue-400 shrink-0" />
            <a href="mailto:sales@convrmotor.com" class="hover:text-white transition-colors">sales@convrmotor.com</a>
          </li>
          <li class="flex items-center space-x-3 text-slate-400">
            <Phone className="w-5 h-5 text-blue-400 shrink-0" />
            <a href="tel:+8615257432470" class="hover:text-white transition-colors">+86 152 5743 2470</a>
          </li>
          <li class="flex items-start space-x-3 text-slate-400">
            <MapPin className="w-5 h-5 text-slate-500 shrink-0 mt-1" />
            <span class="leading-snug text-sm">Building 3, Baolong City Center, Xiaoshan Economic and Technological Development Zone, Hangzhou City, Zhejiang Province, China</span>
          </li>
        </ul>
        <div class="mt-8">
          <a
            href="/rfq"
            class="block w-full text-center px-6 py-4 text-base font-bold text-white bg-linear-to-r from-blue-600 to-blue-700 hover:shadow-xl hover:shadow-blue-900/40 rounded-xl transition-all active:scale-[0.98]"
          >
            Get Technical Quote
          </a>
        </div>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-slate-800/50 flex flex-col md:flex-row justify-between items-center gap-4 text-slate-500 text-sm relative z-10">
      <p>
        &copy; {new Date().getFullYear()} Hejun Electromechanical Technology Co., Ltd.
      </p>
      <div class="flex items-center gap-6 italic">
        <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>IE5 Efficiency Compliance</span>
        <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>ISO 9001 Certified</span>
      </div>
    </div>
  </div>

  <button
    id="back-to-top"
    class="fixed bottom-8 right-8 z-50 w-12 h-12 flex items-center justify-center rounded-xl bg-blue-600 text-white shadow-2xl shadow-blue-900/40 transform translate-y-20 opacity-0 transition-all duration-300 hover:bg-blue-700 active:scale-95 group focus:outline-hidden focus:ring-4 focus:ring-blue-500/50"
    aria-label="Back to Top"
  >
    <ArrowUp className="w-6 h-6 transition-transform group-hover:-translate-y-1" />
  </button>
</footer>

<script>
  // Astro 架构中推荐使用这种方式绑定 JS
  const backToTopButton = document.getElementById('back-to-top');

  if (backToTopButton) {
    // 1. 监听滚动事件，控制按钮显示/隐藏
    window.addEventListener('scroll', () => {
      // 如果滚动高度超过 400px，则显示
      if (window.scrollY > 400) {
        backToTopButton.classList.remove('translate-y-20', 'opacity-0');
        backToTopButton.classList.add('translate-y-0', 'opacity-100');
      } else {
        backToTopButton.classList.remove('translate-y-0', 'opacity-100');
        backToTopButton.classList.add('translate-y-20', 'opacity-0');
      }
    });

    // 2. 监听点击事件，平滑滚动到顶部
    backToTopButton.addEventListener('click', () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth' // 这是平滑滚动的关键
      });
    });
  }
</script>