---
import { NAVIGATION, SOCIAL_LINKS, SITE } from '@config/site';
import { Zap, Linkedin, Twitter, Facebook, Mail, Phone, MapPin } from 'lucide-react';
---

<footer class="bg-slate-900 text-slate-300">
  <div class="container mx-auto px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-4">
      <div class="lg:col-span-1 space-y-6">
        <a href="/" class="flex items-center space-x-3 group">
          <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-linear-to-br from-blue-600 to-teal-600">
            <Zap className="w-7 h-7 text-white" />
          </div>
          <span class="text-2xl font-bold text-white">
            Hejun Motors
          </span>
        </a>
        <p class="text-sm text-slate-400 leading-relaxed max-w-xs">
          Global provider of IE5 ultra-premium efficiency motors and high-performance paper machinery solutions. Engineering excellence for modern industry.
        </p>
        <div class="flex space-x-4">
          <a
            href={SOCIAL_LINKS.linkedin}
            class="w-10 h-10 flex items-center justify-center rounded-lg bg-slate-800 text-slate-400 hover:bg-blue-600 hover:text-white transition-all"
            aria-label="LinkedIn"
          >
            <Linkedin className="w-5 h-5" />
          </a>
          </div>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-6">
          Sitemap
        </h3>
        <ul class="space-y-3">
          {NAVIGATION.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm text-slate-400 hover:text-blue-400 transition-colors inline-flex items-center group"
              >
                <span class="w-0 group-hover:w-2 h-0.5 bg-blue-400 transition-all mr-0 group-hover:mr-2"></span>
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-6">
          Solutions
        </h3>
        <ul class="space-y-3">
          <li>
            <a href="/products" class="text-sm text-slate-400 hover:text-blue-400 transition-colors inline-flex items-center group">
              <span class="w-0 group-hover:w-2 h-0.5 bg-blue-400 transition-all mr-0 group-hover:mr-2"></span>
              IE5 PM Motors
            </a>
          </li>
          <li>
            <a href="/products" class="text-sm text-slate-400 hover:text-blue-400 transition-colors inline-flex items-center group">
              <span class="w-0 group-hover:w-2 h-0.5 bg-blue-400 transition-all mr-0 group-hover:mr-2"></span>
              Paper Machine Drives
            </a>
          </li>
          <li>
            <a href="/products" class="text-sm text-slate-400 hover:text-blue-400 transition-colors inline-flex items-center group">
              <span class="w-0 group-hover:w-2 h-0.5 bg-blue-400 transition-all mr-0 group-hover:mr-2"></span>
              Explosion-proof Motors
            </a>
          </li>
          <li>
            <a href="/rfq" class="text-sm text-slate-400 hover:text-blue-400 transition-colors inline-flex items-center group">
              <span class="w-0 group-hover:w-2 h-0.5 bg-blue-400 transition-all mr-0 group-hover:mr-2"></span>
              Custom OEM Design
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-6">
          Contact Us
        </h3>
        <ul class="space-y-4 text-sm text-slate-400">
          <li class="flex items-center space-x-3">
            <Mail className="w-5 h-5 text-blue-400 shrink-0" />
            <a href="mailto:sales@convrmotor.com" class="hover:text-white transition-colors">sales@convrmotor.com</a>
          </li>
          <li class="flex items-center space-x-3">
            <Phone className="w-5 h-5 text-teal-400 shrink-0" />
            <a href="tel:+8615257432470" class="hover:text-white transition-colors">+86 152 5743 2470</a>
          </li>
          <li class="flex items-start space-x-3">
            <MapPin className="w-5 h-5 text-slate-500 shrink-0 mt-0.5" />
            <span>Industrial Zone, [Your City], Zhejiang, China</span>
          </li>
        </ul>
        
        <div class="mt-8">
          <a
            href="/rfq"
            class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white bg-linear-to-r from-blue-600 to-teal-600 hover:from-blue-700 hover:to-teal-700 rounded-lg shadow-lg hover:shadow-xl transition-all"
          >
            Get Technical Quote
          </a>
        </div>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-slate-800">
      <div class="flex flex-col md:flex-row items-center justify-between space-y-4 md:space-y-0">
        <p class="text-sm text-slate-500">
          &copy; {new Date().getFullYear()} Hejun Motors & Technology Co., Ltd. All rights reserved.
        </p>
        <div class="flex items-center space-x-6 text-sm">
          <a href="/privacy" class="text-slate-500 hover:text-blue-400 transition-colors">
            Privacy Policy
          </a>
          <span class="text-slate-700">•</span>
          <a href="/terms" class="text-slate-500 hover:text-blue-400 transition-colors">
            Terms of Service
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>