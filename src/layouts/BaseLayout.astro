---
import '../styles/global.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import SEO from '@components/SEO.astro'; // 🎯 引入我们之前写好的 SEO 大管家组件
import { SITE } from '@config/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;       // 🎯 新增：接收 WP 详情页传来的分享图
  canonicalUrl?: string;  // 🎯 新增：接收 Yoast 标准规范链接
}

const currentPathname = Astro.url.pathname;

const { 
  title = SITE.title, 
  description = SITE.description,
  ogImage,
  canonicalUrl
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <SEO 
      title={title} 
      description={description} 
      ogImage={ogImage} 
      canonicalUrl={canonicalUrl} 
    />
  </head>
  
  <body class="flex min-h-screen flex-col bg-white font-sans text-neutral-900 antialiased">
    
    <a 
      href="https://wa.me/8615257432470"
      target="_blank" 
      rel="noopener noreferrer"
      class="fixed bottom-2 left-6 z-[99] group flex items-center justify-center w-14 h-14 bg-[#25d366] text-white rounded-full shadow-2xl hover:bg-[#128c7e] hover:scale-110 transition-all duration-300"
      aria-label="Contact us on WhatsApp"
    >
      <span class="absolute inset-0 rounded-full bg-[#25d366] animate-ping opacity-20 group-hover:hidden"></span>
      
      <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>

    <Header currentPathname={currentPathname} />
    
    <main class="flex-1">
      <slot />
    </main>
    
    <Footer />

    <dialog id="global_inquiry_modal" 
      class="fixed inset-0 m-auto z-[999]
             backdrop:bg-slate-900/60 backdrop:backdrop-blur-sm 
             rounded-2xl shadow-2xl p-0 w-[90%] max-w-lg border-none overflow-hidden"
    >
      <div class="bg-white relative">
        <div class="h-2 bg-blue-600 w-full"></div>
        
        <div class="p-8">
          <button onclick="window.global_inquiry_modal.close()" class="absolute right-6 top-8 text-slate-400 hover:text-slate-900 transition-colors cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>

          <div class="mb-8 text-left">
            <h3 class="text-2xl font-black text-slate-900 uppercase tracking-tighter italic">Quick Inquiry</h3>
            <p class="text-sm text-slate-500 mt-2 font-medium">Leave your requirements and we'll contact you within 24h.</p>
          </div>  

          <form action="https://formspree.io/f/mbdqbvyw" method="POST" class="space-y-4">
            <input type="hidden" name="_source_page" id="modal_source_page" value="" />
            
            <div class="grid grid-cols-1 gap-4 text-left">
              <div>
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1.5">Full Name</label>
                <input type="text" name="name" required class="w-full px-4 py-3.5 bg-slate-50 border border-slate-200 rounded-xl focus:border-blue-600 outline-none text-sm font-bold" placeholder="Your Name" />
              </div>
              <div>
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1.5">Work Email</label>
                <input type="email" name="email" required class="w-full px-4 py-3.5 bg-slate-50 border border-slate-200 rounded-xl focus:border-blue-600 outline-none text-sm font-bold" placeholder="email@company.com" />
              </div>
              <div>
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1.5">Message</label>
                <textarea name="message" rows="4" required class="w-full px-4 py-3.5 bg-slate-50 border border-slate-200 rounded-xl focus:border-blue-600 outline-none text-sm font-bold" placeholder="Tell us what you need..."></textarea>
              </div>
            </div>

            <button id="submit_btn" type="submit" 
              class="w-full py-4 bg-[#001e3c] text-white font-black text-[11px] uppercase tracking-[0.2em] rounded-xl 
                     transition-colors duration-200 hover:bg-blue-600 cursor-pointer mt-2 shadow-lg"
            >
              Send Inquiry Now
            </button>
          </form>
        </div>
      </div>
    </dialog>

    <script is:inline>
      // 1. 全局调起弹窗方法
      window.openInquiryModal = () => {
        const modal = document.getElementById('global_inquiry_modal');
        const sourceInput = document.getElementById('modal_source_page');
        if (modal) {
          if (sourceInput) sourceInput.value = window.location.href;
          modal.showModal();
        }
      }

      // 2. 异步提交并跳转
      const inquiryForm = document.querySelector('#global_inquiry_modal form');
      inquiryForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('submit_btn');
        const originalText = btn.innerText;
        
        btn.innerText = "SENDING...";
        btn.disabled = true;

        const formData = new FormData(inquiryForm);
        try {
          const response = await fetch(inquiryForm.action, {
            method: 'POST',
            body: formData,
            headers: { 'Accept': 'application/json' }
          });
          if (response.ok) {
            window.location.href = '/thanks'; 
          } else {
            throw new Error();
          }
        } catch (err) {
          alert("Submission failed. Please check your network.");
          btn.innerText = originalText;
          btn.disabled = false;
        }
      });

      // 3. 点击背景自动关闭弹窗
      const modal = document.getElementById('global_inquiry_modal');
      modal?.addEventListener('click', (e) => {
        if (e.target === modal) modal.close();
      });
    </script>

    <style is:global>
      /* 强制 dialog 垂直水平居中渲染 */
      dialog[open] {
        display: flex;
        flex-direction: column;
        animation: modal-appear 0.25s ease-out forwards;
      }
      
      @keyframes modal-appear {
        from { 
          opacity: 0; 
          transform: translateY(20px) scale(0.98); 
        }
        to { 
          opacity: 1; 
          transform: translateY(0) scale(1); 
        }
      }

      /* 遮罩层模糊效果 */
      dialog::backdrop {
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(8px);
      }

      /* 防止弹窗打开时页面还可以滚动 */
      html:has(dialog[open]) {
        overflow: hidden;
      }
    </style>
  </body>
</html>