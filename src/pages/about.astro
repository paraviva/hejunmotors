---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Settings2, ShieldCheck, PenTool, Truck, CheckCircle2, LifeBuoy, ArrowRight } from 'lucide-react';

const workflow = [
  { 
    phase: "Phase 1", 
    title: "Requirement Confirmation", 
    desc: "Technica: Client provides specifications (motor parameters or paper machine capacity/process requirements); Proposal Submission: We provide technical solutions, equipment lists, and preliminary quotations", 
    icon: Settings2,
    details: ["Motor parameters", "Paper machine capacity", "Preliminary quotations"]
  },
  { 
    phase: "Phase 2", 
    title: "Agreement Finalization", 
    desc: "Technical Validation: Meeting to confirm all technical details and standards; Contract Signing: Formal contract execution covering payment terms, delivery schedule, and acceptance criteria", 
    icon: ShieldCheck,
    details: ["Technical standards", "Payment terms", "Acceptance criteria"]
  },
  { 
    phase: "Phase 3", 
    title: "Production & Quality Assurance", 
    desc: "Production Initiation: Motor production scheduling / Paper machine detailed design & procurement; Process Monitoring: Regular progress reports, support for client factory inspection or remote supervision; Factory Acceptance: Motors come with test reports / Paper machines undergo Factory Acceptance Test", 
    icon: PenTool,
    details: ["Progress reports", "Factory inspection", "Test reports"]
  },
  { 
    phase: "Phase 4", 
    title: "Delivery", 
    desc: "FOB Delivery: Equipment ready at the designated port; we coordinate with the client's freight forwarder for export customs clearance.; EXW Delivery: Equipment ready at our factory; the client or their agent arranges pickup and handles all export procedures.; Documentation: We provide a full set of customs documents (Invoice, packing list, certificate of origin, test reports).", 
    icon: Truck,
    details: ["Export clearance", "Packing list", "Certificate of origin"]
  },
  { 
    phase: "Phase 5", 
    title: "Installation", 
    desc: "Motor: Provide installation guides with optional on-line support; Paper Machine: Dispatch engineers for installation supervision, commissioning, and operator training", 
    icon: CheckCircle2,
    details: ["Installation guides", "Commissioning", "Remote support"]
  },
  { 
    phase: "Phase 6", 
    title: "After-sales & Warranty", 
    desc: "Final Acceptance: Sign acceptance documentation to activate warranty period; Ongoing Support: Spare parts supply, remote technical support, and maintenance planning", 
    icon: LifeBuoy,
    details: ["Final acceptance", "Maintenance planning", "Rapid response"]
  },
];
---

<BaseLayout title="About Us | Hejun Motors">
  <section class="relative py-28 bg-slate-900 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-40">
      <img src="/image/banner2.webp" class="w-full h-full object-cover" alt="Industrial Innovation" />
    </div>
    <div class="container mx-auto px-6 relative z-10 text-left">
      <div class="max-w-4xl">
        <div class="inline-block px-4 py-1 mb-4 bg-blue-600/20 border border-blue-500/30 rounded-full text-blue-400 text-sm font-semibold tracking-wider uppercase">
          Corporate Identity
        </div>
        <h1 class="text-4xl md:text-6xl font-bold mb-8 leading-tight">
          Industrial Power & <br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-teal-400">
            Papermaking Systems Innovator
          </span>
        </h1>
        <p class="text-xl text-slate-300 max-w-2xl leading-relaxed">
          Integrating advanced motor-drive systems with intelligent papermaking machinery to drive global productivity.
        </p>
      </div>
    </div>
  </section>

  <section class="py-24 bg-slate-50">
    <div class="container mx-auto px-6">
      <div class="max-w-6xl mx-auto">
          <div class="text-center mb-20">
              <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6 uppercase tracking-wider">Our Mission</h2>
              <p class="text-xl text-slate-600 leading-relaxed italic max-w-4xl mx-auto">
                "To power global manufacturing with reliable, efficient, and sustainable solutions that drive productivity while reducing environmental impact."
              </p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <div class="group p-10 bg-white rounded-2xl shadow-xl border border-slate-100 hover:border-blue-200 transition-all hover:-translate-y-1">
              <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-6">
                <div class="w-4 h-4 bg-blue-600 rounded-full animate-pulse"></div>
              </div>
              <h4 class="text-2xl font-bold mb-4 text-slate-900 italic">Industrial Motors & Drives</h4>
              <p class="text-slate-600 leading-relaxed">From precision servo systems to heavy-duty explosion-proof motors, designed for industries ranging from mining and water treatment to automation and renewable energy.</p>
            </div>

            <div class="group p-10 bg-white rounded-2xl shadow-xl border border-slate-100 hover:border-teal-200 transition-all hover:-translate-y-1">
              <div class="w-12 h-12 bg-teal-100 rounded-lg flex items-center justify-center mb-6">
                <div class="w-4 h-4 bg-teal-500 rounded-full animate-pulse"></div>
              </div>
              <h4 class="text-2xl font-bold mb-4 text-slate-900 italic">Complete Papermaking Lines</h4>
              <p class="text-slate-600 leading-relaxed">Integrated solutions from pulping and forming to drying and finishing, tailored for tissue, packaging, specialty paper, and custom production requirements.</p>
            </div>
          </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-slate-900 text-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-20">
        <h2 class="text-3xl md:text-5xl font-bold mb-4 italic tracking-tighter">Procurement Process</h2>
        <p class="text-slate-400 max-w-2xl mx-auto">A systematic 6-phase approach ensuring technical precision and global delivery standards.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-y-16 gap-x-12">
        {workflow.map((item) => (
          <div class="relative group">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-14 h-14 bg-blue-600 rounded-xl flex items-center justify-center group-hover:rotate-6 transition-transform shadow-lg shadow-blue-900/40">
                <item.icon className="w-7 h-7 text-white" />
              </div>
              <span class="text-sm font-mono text-blue-400 font-bold uppercase">{item.phase}</span>
            </div>
            <h3 class="text-xl font-bold mb-4 text-white group-hover:text-blue-400 transition-colors">{item.title}</h3>
            <p class="text-slate-400 text-sm mb-6 leading-relaxed min-h-[80px]">{item.desc}</p>
            <ul class="space-y-3 border-t border-slate-800 pt-6">
              {item.details.map(detail => (
                <li class="flex items-center gap-3 text-xs text-slate-500">
                  <ArrowRight className="w-3 h-3 text-blue-600 shrink-0" />
                  <span class="group-hover:text-slate-300 transition-colors">{detail}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 bg-blue-700 relative overflow-hidden">
    <div class="absolute inset-0 bg-[url('/image/grid.svg')] opacity-10"></div>
    <div class="container mx-auto px-6 text-center relative z-10">
      <h2 class="text-4xl font-bold text-white mb-10 tracking-tight">Ready to Optimize Your Production?</h2>
      <a href="/rfq" class="group inline-flex items-center px-10 py-5 bg-white text-blue-700 font-bold rounded-full hover:bg-slate-50 transition-all shadow-2xl hover:-translate-y-1">
        Start Your Project
        <ArrowRight className="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform" />
      </a>
    </div>
  </section>
</BaseLayout>