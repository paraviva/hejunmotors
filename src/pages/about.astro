---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/ui/Section.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import { Image } from 'astro:assets';
// 这里的组件路径根据你刚才发的模板对齐
import ImageReveal from '../components/react/ImageReveal';

// 导入你项目中的工业图片（如果路径不对，明天记得改一下）
import manufacturingImg from '../assets/images/banner1.webp'; 

const workflow = [
  { step: '01', title: 'Requirement', desc: 'Technical specs confirmation & proposal submission.' },
  { step: '02', title: 'Agreement', desc: 'Technical validation & formal contract execution.' },
  { step: '03', title: 'Production', desc: 'Manufacturing & process quality assurance (QA).' },
  { step: '04', title: 'Delivery', desc: 'FOB/EXW logistics & customs documentation.' },
  { step: '05', title: 'Installation', desc: 'On-site supervision & operator training.' },
  { step: '06', title: 'After-sales', desc: 'Warranty activation & spare parts supply.' }
];
---

<BaseLayout title="About Us - Hejun Motors">
  <header class="py-20 bg-slate-900">
    <div class="container mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-4 tracking-tighter uppercase italic">About Us</h1>
      <div class="w-20 h-1.5 bg-linear-to-r from-blue-600 to-teal-500 mx-auto mb-4"></div>
      <p class="text-blue-400 font-mono text-sm tracking-widest uppercase">Industrial Power & Papermaking Systems Innovator</p>
    </div>
  </header>

  <Section background="white">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <ImageReveal client:load>
          <div class="relative aspect-square overflow-hidden rounded-3xl shadow-2xl group">
            <img 
              src="/image/banner2.webp" 
              alt="Industrial Excellence" 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
            <div class="absolute inset-0 bg-linear-to-t from-slate-900/60 via-transparent to-transparent"></div>
            <div class="absolute bottom-8 left-8 text-white">
                <p class="text-sm font-mono text-blue-400 mb-2">SINCE 2005</p>
                <h3 class="text-2xl font-bold">Engineering Excellence</h3>
            </div>
          </div>
        </ImageReveal>
      </div>

      <div class="animate-fadeInUp">
        <div class="inline-flex items-center px-4 py-2 mb-6 bg-blue-50 text-blue-700 text-sm font-semibold rounded-full">
          Corporate Identity
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-8 italic">Who We Are</h2>
        <div class="p-8 bg-slate-50 rounded-2xl border-l-4 border-blue-600 shadow-sm">
          <p class="text-lg md:text-xl text-gray-700 leading-relaxed text-justify">
            We are an industrial technology enterprise dedicated to integrating advanced motor-drive systems with intelligent papermaking machinery. Our mission is to power global manufacturing with reliable, efficient, and sustainable solutions that drive productivity while reducing environmental impact. Specializing in two core domains, we engineer motion and transformation: Industrial Motors & Drives – from precision servo systems to heavy-duty explosion-proof motors, designed for industries ranging from mining and water treatment to automation and renewable energy. Complete Papermaking Lines – offering integrated solutions from pulping and forming to drying and finishing, tailored for tissue, packaging, and specialty paper production. Through continuous innovation in automation, energy efficiency, and intelligent control, we help clients optimize operational performance, lower lifecycle costs, and advance toward greener production practices. Whether powering a single machine or delivering a turnkey paper plant, we combine engineering excellence with a deep understanding of industrial processes. Committed to quality and collaboration, we work closely with customers worldwide to build systems that move industries forward—responsibly, reliably, and ahead of schedule.
          </p>
        </div>
      </div>
    </div>
  </Section>

  <Section background="gray">
    <div class="text-center mb-16">
      <div class="inline-block px-4 py-2 mb-4 bg-blue-100 text-blue-800 text-sm font-semibold rounded-full">
        Our Approach
      </div>
      <h2 class="text-4xl font-bold text-gray-900 mb-4 italic">
        Procurement <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-600 to-teal-600">Process</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        A streamlined, 6-phase approach ensuring technical precision and delivery.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {workflow.map((process, index) => (
        <Card hover class="animate-fadeInUp group" style={`animation-delay: ${index * 0.1}s`}>
          <div class="flex items-center justify-between mb-6">
            <div class="text-4xl font-black text-slate-200 group-hover:text-blue-100 transition-colors">{process.step}</div>
            <div class="w-10 h-10 rounded-lg bg-blue-600 flex items-center justify-center text-white shadow-lg group-hover:rotate-12 transition-transform">
               <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            </div>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">{process.title}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{process.desc}</p>
        </Card>
      ))}
    </div>
  </Section>

  <section class="relative py-32 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/image/banner1.webp" class="w-full h-full object-cover" alt="CTA" />
      <div class="absolute inset-0 bg-linear-to-r from-blue-900/95 to-teal-900/95"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10 text-center text-white">
      <h2 class="text-4xl md:text-6xl font-bold mb-8 leading-tight">Ready to Start Your Project?</h2>
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <Button href="/rfq" size="lg" class="bg-white! text-blue-700! hover:bg-slate-100!">
          Request a Quote
        </Button>
        <Button href="/contact" size="lg" variant="outline" class="border-2! border-white! text-white! hover:bg-white/10!">
          Contact Us
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>