---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/ui/Section.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import { Image } from 'astro:assets';
import ImageReveal from '../components/react/ImageReveal';

// 保持使用你模板中的图片引用方式，确保路径正确
import manufacturingImg from '@assets/photo-1581091226825-a6a2a5aee158.jpg';
import ctaBgImg from '@assets/photo-1553413077-190dd305871c.jpg';

const workflow = [
  { 
    step: '01', 
    title: 'Requirement', 
    description: 'Technical specs confirmation (motor params or paper process) & initial proposal submission.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>`
  },
  { 
    step: '02', 
    title: 'Agreement', 
    description: 'Meeting to confirm all technical standards followed by formal contract execution.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2C9.47 2 7.153 3.063 5.382 4.784a11.955 11.955 0 01-1.012 1.411A11.954 11.954 0 003 12c0 1.268.197 2.49.563 3.637a11.954 11.954 0 005.259 6.643L12 23l3.178-1.72a11.954 11.954 0 005.259-6.643c.366-1.147.563-2.369.563-3.637 0-2.348-.674-4.538-1.832-6.384z" /></svg>`
  },
  { 
    step: '03', 
    title: 'Production', 
    description: 'Production scheduling with regular progress reports and factory acceptance testing.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>`
  },
  { 
    step: '04', 
    title: 'Delivery', 
    description: 'FOB/EXW coordination with full documentation (Invoice, PL, CO, Test Reports).',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>`
  },
  { 
    step: '05', 
    title: 'Installation', 
    description: 'On-site installation supervision, commissioning, and professional operator training.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`
  },
  { 
    step: '06', 
    title: 'Support', 
    description: 'Warranty activation, spare parts supply, and remote technical maintenance planning.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" /></svg>`
  }
];
---

<BaseLayout title="About Us | Hejun Motors">
  <header class="py-20 bg-slate-900 border-b border-slate-800">
    <div class="container mx-auto px-6 text-center">
      <div class="inline-flex items-center px-4 py-2 mb-6 bg-blue-600/10 text-blue-400 text-sm font-mono tracking-widest rounded-full border border-blue-600/20">
        SINCE 2005
      </div>
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 tracking-tighter italic">
        ABOUT <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-400 via-teal-400 to-blue-400">US</span>
      </h1>
      <p class="text-slate-400 max-w-2xl mx-auto font-light text-lg">
        Industrial Power & Papermaking Systems Innovator
      </p>
    </div>
  </header>

  <Section background="white">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="order-2 lg:order-1">
        <ImageReveal client:load>
          <div class="relative aspect-square overflow-hidden rounded-3xl shadow-2xl group">
            <Image 
              src={manufacturingImg}
              alt="Hejun Motors Manufacturing"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              width={1000}
              height={1000}
            />
            <div class="absolute inset-0 bg-linear-to-t from-slate-900/60 via-transparent to-transparent"></div>
          </div>
        </ImageReveal>
      </div>

      <div class="order-1 lg:order-2 animate-fadeInUp">
        <div class="w-12 h-1 bg-blue-600 mb-8"></div>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-8 italic">Engineering Excellence & Innovation</h2>
        <div class="bg-slate-50 p-8 md:p-10 rounded-2xl border border-slate-100 shadow-sm">
          <p class="text-lg md:text-xl text-gray-700 leading-relaxed text-justify">
            We are an industrial technology enterprise dedicated to integrating advanced motor-drive systems with intelligent papermaking machinery. Our mission is to power global manufacturing with reliable, efficient, and sustainable solutions that drive productivity while reducing environmental impact. Specializing in two core domains, we engineer motion and transformation: Industrial Motors & Drives – from precision servo systems to heavy-duty explosion-proof motors, designed for industries ranging from mining and water treatment to automation and renewable energy. Complete Papermaking Lines – offering integrated solutions from pulping and forming to drying and finishing, tailored for tissue, packaging, and specialty paper production. Through continuous innovation in automation, energy efficiency, and intelligent control, we help clients optimize operational performance, lower lifecycle costs, and advance toward greener production practices. Whether powering a single machine or delivering a turnkey paper plant, we combine engineering excellence with a deep understanding of industrial processes. Committed to quality and collaboration, we work closely with customers worldwide to build systems that move industries forward—responsibly, reliably, and ahead of schedule.
          </p>
        </div>
      </div>
    </div>
  </Section>

  <Section background="gray">
    <div class="text-center mb-16">
      <div class="inline-block px-4 py-2 mb-4 bg-blue-100 text-blue-800 text-sm font-semibold rounded-full uppercase tracking-widest">
        Workflow
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Procurement <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-600 to-teal-600">Process</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        A systematic 6-phase approach ensuring technical precision and reliable delivery.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {workflow.map((process, index) => (
        <Card hover class="animate-fadeInUp group" style={`animation-delay: ${index * 0.1}s`}>
          <div class="flex items-center justify-center w-16 h-16 mb-6 rounded-xl bg-linear-to-br from-blue-600 to-teal-500 text-white shadow-lg group-hover:scale-110 group-hover:rotate-6 transition-all duration-300">
            <div set:html={process.icon} />
          </div>
          <div class="text-3xl font-black text-transparent bg-clip-text bg-linear-to-r from-blue-600/20 to-teal-600/20 mb-2 font-mono">
            {process.step}
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">{process.title}</h3>
          <p class="text-gray-600 leading-relaxed text-sm">{process.description}</p>
        </Card>
      ))}
    </div>
  </Section>

  <section class="relative py-32 overflow-hidden">
    <div class="absolute inset-0">
      <Image 
        src={ctaBgImg}
        alt="Industrial Partnership"
        class="w-full h-full object-cover"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 bg-linear-to-r from-slate-900/95 to-blue-900/90"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10 text-center">
      <h2 class="text-4xl md:text-6xl font-bold text-white mb-8 leading-tight">
        Ready to Power Your <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-400 to-teal-400">Production</span>?
      </h2>
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <Button href="/rfq" size="lg" class="bg-blue-600! hover:bg-blue-700! text-white! shadow-2xl!">
          Request a Quote
        </Button>
        <Button href="/contact" size="lg" variant="outline" class="border-2! border-white! text-white! hover:bg-white/10!">
          Contact Our Team
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>