---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/ui/Section.astro';
import Card from '../components/ui/Card.astro';
import { Image } from 'astro:assets';
import { 
  Users, Zap, Shield, TrendingUp, Award, CheckCircle2, FileText
} from 'lucide-react';

// 使用你提供的 RFQ 资源路径
import rfqBgImg from '@assets/photo-1558618666-fcd25c85cd64.jpg';
import warehouseImg from '@assets/photo-1563013544-824ae1b704d3.jpg';

const companyShowcaseImg = "/image/aboutus.webp";

const procurementPhases = [
  {
    phase: 'Phase 1',
    title: 'Requirement Confirmation',
    items: [
      { subtitle: 'Technical', desc: 'Client provides specifications (motor parameters or paper machine capacity)' },
      { subtitle: 'Proposal Submission', desc: 'We provide technical solutions and preliminary quotations' }
    ]
  },
  {
    phase: 'Phase 2',
    title: 'Agreement Finalization',
    items: [
      { subtitle: 'Technical Validation', desc: 'Meeting to confirm all technical details and standards' },
      { subtitle: 'Contract Signing', desc: 'Formal contract execution covering payment and delivery' }
    ]
  },
  {
    phase: 'Phase 3',
    title: 'Production & Quality Assurance',
    items: [
      { subtitle: 'Production Initiation', desc: 'Motor production scheduling / Paper machine detailed design' },
      { subtitle: 'Factory Acceptance', desc: 'Motors come with test reports / Paper machines undergo FAT' }
    ]
  },
  {
    phase: 'Phase 4',
    title: 'Delivery',
    items: [
      { subtitle: 'FOB/EXW Delivery', desc: 'Flexible coordination for port-ready or factory-gate pickup' },
      { subtitle: 'Documentation', desc: 'Full set of customs documents (invoice, packing list, CO)' }
    ]
  },
  {
    phase: 'Phase 5',
    title: 'Installation',
    items: [
      { subtitle: 'Motor', desc: 'Provide installation guides with optional on-line support' },
      { subtitle: 'Paper Machine', desc: 'Dispatch engineers for installation and operator training' }
    ]
  },
  {
    phase: 'Phase 6',
    title: 'After-sales & Warranty',
    items: [
      { subtitle: 'Final Acceptance', desc: 'Sign acceptance documentation to activate warranty' },
      { subtitle: 'Ongoing Support', desc: 'Spare parts supply and maintenance planning' }
    ]
  }
];
---

<BaseLayout title="About Us - Hejun Motors | Industrial Power Innovator">
  <section class="relative h-[600px] md:h-[700px] flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <Image 
        src={rfqBgImg}
        alt="Professional industrial motor manufacturing"
        class="w-full h-full object-cover"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/95 via-blue-900/90 to-slate-900/85"></div>
    </div>

    <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center px-4 py-2 mb-6 bg-gradient-to-r from-blue-600 to-teal-600 text-white text-sm font-semibold rounded-full shadow-lg">
          <Award className="w-4 h-4 mr-2" />
          Driving Industrial Excellence Since 2011
        </div>
        
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
          Industrial Power & <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-teal-400 to-blue-400">Systems Innovator</span>
        </h1>
        
        <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed">
          We integrate advanced motor-drive systems with intelligent papermaking machinery to power global manufacturing with efficiency and sustainability.
        </p>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 pt-8 border-t border-white/20 mt-8">
          <div class="group">
            <div class="text-3xl md:text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-white to-blue-200 mb-1">15+</div>
            <div class="text-sm text-slate-300 group-hover:text-teal-300 transition-colors">Years Experience</div>
          </div>
          <div class="group">
            <div class="text-3xl md:text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-white to-blue-200 mb-1">IE5</div>
            <div class="text-sm text-slate-300 group-hover:text-teal-300 transition-colors">Efficiency Level</div>
          </div>
          <div class="group">
            <div class="text-3xl md:text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-white to-blue-200 mb-1">99.9%</div>
            <div class="text-sm text-slate-300 group-hover:text-teal-300 transition-colors">On-Time Rate</div>
          </div>
          <div class="group">
            <div class="text-3xl md:text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-white to-blue-200 mb-1">24hr</div>
            <div class="text-sm text-slate-300 group-hover:text-teal-300 transition-colors">Response Time</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Section background="white">
    <div class="container mx-auto px-4 py-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="relative group">
          <div class="absolute -top-6 -left-6 w-32 h-32 bg-blue-600/5 rounded-full blur-3xl"></div>
          <img 
            src={companyShowcaseImg} 
            alt="Hejun Industrial Showcase" 
            class="relative w-full rounded-2xl shadow-2xl border border-slate-100 z-10 transition-transform duration-500 group-hover:scale-[1.01]"
          />
        </div>
        
        <div class="space-y-8">
          <div class="space-y-4 text-slate-700">
            <h2 class="text-3xl font-bold text-slate-900 leading-tight">Our Mission & Vision</h2>
            <p class="text-lg leading-relaxed">
              We are an industrial technology enterprise dedicated to integrating advanced motor-drive systems with intelligent papermaking machinery. Our mission is to power global manufacturing with reliable, efficient, and sustainable solutions that drive productivity while reducing environmental impact.
            </p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="p-5 bg-slate-50 rounded-xl border-l-4 border-blue-600 shadow-sm flex items-start space-x-3">
              <Zap className="w-6 h-6 text-blue-600 shrink-0 mt-1" />
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Motors & Drives</h4>
                <p class="text-xs text-slate-600">Precision servo systems and heavy-duty motors.</p>
              </div>
            </div>
            <div class="p-5 bg-slate-50 rounded-xl border-l-4 border-teal-500 shadow-sm flex items-start space-x-3">
              <TrendingUp className="w-6 h-6 text-teal-600 shrink-0 mt-1" />
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Complete Lines</h4>
                <p class="text-xs text-slate-600">Integrated solutions from pulping to finishing.</p>
              </div>
            </div>
          </div>

          <p class="text-slate-600 leading-relaxed">
            Whether powering a single machine or delivering a turnkey paper plant, we combine engineering excellence with a deep understanding of industrial processes.
          </p>
        </div>
      </div>
    </div>
  </Section>

  <Section background="gray">
    <div class="text-center mb-16 px-4">
      <div class="inline-block px-4 py-1 mb-4 bg-blue-100 text-blue-800 text-xs font-bold rounded-full uppercase tracking-widest">Our Execution</div>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 uppercase tracking-tight">Procurement <span class="text-blue-600">Process</span></h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 container mx-auto px-4">
      {procurementPhases.map((p) => (
        <Card class="group p-8 bg-white border border-slate-200 hover:border-blue-500 transition-all duration-300 relative">
          <div class="flex justify-between items-start mb-6">
            <span class="text-xs font-black text-blue-600 uppercase tracking-widest bg-blue-50 px-2 py-1 rounded">{p.phase}</span>
            <CheckCircle2 className="w-5 h-5 text-slate-200 group-hover:text-blue-500 transition-colors" />
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-6">{p.title}</h3>
          <div class="space-y-4">
            {p.items.map(item => (
              <div class="pl-4 border-l-2 border-slate-100 group-hover:border-blue-400 transition-colors">
                <h4 class="text-[10px] font-black text-slate-400 uppercase mb-1 tracking-wider">{item.subtitle}</h4>
                <p class="text-sm text-slate-600 leading-snug">{item.desc}</p>
              </div>
            ))}
          </div>
        </Card>
      ))}
    </div>
  </Section>
</BaseLayout>