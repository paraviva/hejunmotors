---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Settings2, ShieldCheck, PenTool, Truck, CheckCircle2, LifeBuoy } from 'lucide-react';

const workflow = [
  { 
    phase: "Phase 1", 
    title: "Requirement Confirmation", 
    desc: "Technica: Client provides specifications (motor parameters or paper machine capacity/process requirements); Proposal Submission: We provide technical solutions, equipment lists, and preliminary quotations.", 
    icon: Settings2 
  },
  { 
    phase: "Phase 2", 
    title: "Agreement Finalization", 
    desc: "Technical Validation: Meeting to confirm all technical details and standards; Contract Signing: Formal contract execution covering payment terms, delivery schedule, and acceptance criteria.", 
    icon: ShieldCheck 
  },
  { 
    phase: "Phase 3", 
    title: "Production & Quality Assurance", 
    desc: "Production Initiation: Motor production scheduling / Paper machine detailed design & procurement; Process Monitoring: Regular progress reports, support for client factory inspection or remote supervision; Factory Acceptance: Motors come with test reports / Paper machines undergo Factory Acceptance Test.", 
    icon: PenTool 
  },
  { 
    phase: "Phase 4", 
    title: "Delivery", 
    desc: "FOB Delivery: Equipment ready at the designated port; we coordinate with the client's freight forwarder for export customs clearance. EXW Delivery: Equipment ready at our factory; the client or their agent arranges pickup and handles all export procedures. Documentation: We provide a full set of customs documents (Invoice, packing list, certificate of origin, test reports).", 
    icon: Truck 
  },
  { 
    phase: "Phase 5", 
    title: "Installation", 
    desc: "Motor: Provide installation guides with optional on-line support; Paper Machine: Dispatch engineers for installation supervision, commissioning, and operator training.", 
    icon: CheckCircle2 
  },
  { 
    phase: "Phase 6", 
    title: "After-sales & Warranty", 
    desc: "Final Acceptance: Sign acceptance documentation to activate warranty period; Ongoing Support: Spare parts supply, remote technical support, and maintenance planning.", 
    icon: LifeBuoy 
  }
];
---

<BaseLayout title="About Us | Hejun Motors">
  <section class="relative py-24 bg-slate-900 text-white">
    <div class="absolute inset-0 opacity-30">
      <img src="/image/banner2.webp" class="w-full h-full object-cover" alt="Industrial" />
    </div>
    <div class="container mx-auto px-6 relative z-10 text-center">
      <h1 class="text-4xl md:text-6xl font-bold mb-4 tracking-tight">ABOUT US</h1>
      <p class="text-blue-400 font-mono tracking-widest uppercase">Industrial Power & Papermaking Systems Innovator</p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="max-w-5xl mx-auto">
        <div class="bg-slate-50 p-10 md:p-16 rounded-[2rem] border border-slate-100 shadow-sm">
          <p class="text-xl md:text-2xl text-slate-800 leading-relaxed font-light text-justify">
            We are an industrial technology enterprise dedicated to integrating advanced motor-drive systems with intelligent papermaking machinery. Our mission is to power global manufacturing with reliable, efficient, and sustainable solutions that drive productivity while reducing environmental impact. Specializing in two core domains, we engineer motion and transformation: Industrial Motors & Drives – from precision servo systems to heavy-duty explosion-proof motors, designed for industries ranging from mining and water treatment to automation and renewable energy. Complete Papermaking Lines – offering integrated solutions from pulping and forming to drying and finishing, tailored for tissue, packaging, and specialty paper production. Through continuous innovation in automation, energy efficiency, and intelligent control, we help clients optimize operational performance, lower lifecycle costs, and advance toward greener production practices. Whether powering a single machine or delivering a turnkey paper plant, we combine engineering excellence with a deep understanding of industrial processes. Committed to quality and collaboration, we work closely with customers worldwide to build systems that move industries forward—responsibly, reliably, and ahead of schedule.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-slate-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-20">
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">Industrial Equipment Procurement Process</h2>
        <div class="w-24 h-1.5 bg-blue-600 mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {workflow.map((item) => (
          <div class="bg-slate-800/50 p-8 rounded-2xl border border-slate-700 hover:border-blue-500 transition-all duration-300 group">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 bg-blue-600 rounded-lg flex items-center justify-center group-hover:rotate-6 transition-transform">
                <item.icon className="w-6 h-6 text-white" />
              </div>
              <span class="text-blue-400 font-mono font-bold tracking-tighter">{item.phase}</span>
            </div>
            <h3 class="text-xl font-bold text-white mb-4 leading-tight">{item.title}</h3>
            <div class="h-px bg-slate-700 w-full mb-6"></div>
            <p class="text-slate-400 text-sm leading-relaxed">
              {item.desc}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-blue-600 text-center">
    <div class="container mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-10">Start Your Industrial Journey With Us</h2>
      <a href="/contact" class="px-10 py-4 bg-white text-blue-700 font-bold rounded-full hover:bg-slate-100 transition-all shadow-xl">
        Get A Quote Now
      </a>
    </div>
  </section>
</BaseLayout>