---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../ui/Section.astro';
import { Settings2, ShieldCheck, PenTool, Truck, CheckCircle2, LifeBuoy, ArrowRight } from 'lucide-react';

const workflow = [
  { 
    phase: "Phase 1", 
    title: "Requirement", 
    desc: "Technical specs confirmation & proposal submission", 
    icon: Settings2,
    details: ["Motor parameters", "Paper machine capacity", "Preliminary quotations"]
  },
  { 
    phase: "Phase 2", 
    title: "Agreement", 
    desc: "Technical validation & formal contract execution", 
    icon: ShieldCheck,
    details: ["Technical standards", "Payment terms", "Acceptance criteria"]
  },
  { 
    phase: "Phase 3", 
    title: "Production", 
    desc: "Manufacturing & process quality assurance", 
    icon: PenTool,
    details: ["Progress reports", "Factory inspection", "Test reports"]
  },
  { 
    phase: "Phase 4", 
    title: "Delivery", 
    desc: "FOB/EXW logistics & customs documentation", 
    icon: Truck,
    details: ["Export clearance", "Packing list", "Certificate of origin"]
  },
  { 
    phase: "Phase 5", 
    title: "Installation", 
    desc: "On-site supervision & operator training", 
    icon: CheckCircle2,
    details: ["Installation guides", "Commissioning", "Remote support"]
  },
  { 
    phase: "Phase 6", 
    title: "After-sales", 
    desc: "Warranty activation & spare parts supply", 
    icon: LifeBuoy,
    details: ["Final acceptance", "Maintenance planning", "Rapid response"]
  },
];
---

<BaseLayout title="About Us | Hejun Motors">
  <section class="relative py-28 bg-slate-900 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-40">
      <img src="/image/banner2.webp" class="w-full h-full object-cover" alt="Industrial Innovation" />
    </div>
    <div class="container mx-auto px-6 relative z-10">
      <div class="max-w-4xl">
        <div class="inline-block px-4 py-1 mb-4 bg-blue-600/20 border border-blue-500/30 rounded-full text-blue-400 text-sm font-semibold tracking-wider">
          ESTABLISHED PERFORMANCE
        </div>
        <h1 class="text-4xl md:text-6xl font-bold mb-8 leading-tight">
          Industrial Power & <br/>
          <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-400 to-teal-400">
            Papermaking Systems Innovator
          </span>
        </h1>
        <p class="text-xl text-slate-300 max-w-2xl leading-relaxed">
          Integrating advanced motor-drive systems with intelligent papermaking machinery to drive global productivity.
        </p>
      </div>
    </div>
  </section>

  <Section>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-start">
      <div class="space-y-8">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900">Our Mission</h2>
        <p class="text-lg text-slate-600 leading-relaxed italic border-l-4 border-blue-600 pl-6">
          "To power global manufacturing with reliable, efficient, and sustainable solutions that drive productivity while reducing environmental impact."
        </p>
        <div class="space-y-6">
          <div class="group p-6 bg-slate-50 rounded-xl hover:bg-blue-50 transition-colors">
            <h4 class="text-xl font-bold mb-3 flex items-center gap-2">
              <span class="w-2 h-2 bg-blue-600 rounded-full"></span>
              Industrial Motors & Drives
            </h4>
            <p class="text-slate-600">From precision servo systems to heavy-duty explosion-proof motors, designed for mining, water treatment, and renewable energy.</p>
          </div>
          <div class="group p-6 bg-slate-50 rounded-xl hover:bg-teal-50 transition-colors">
            <h4 class="text-xl font-bold mb-3 flex items-center gap-2">
              <span class="w-2 h-2 bg-teal-500 rounded-full"></span>
              Complete Papermaking Lines
            </h4>
            <p class="text-slate-600">Integrated solutions from pulping to drying, tailored for tissue, packaging, and specialty paper production.</p>
          </div>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div class="space-y-4 pt-12">
          <img src="/image/banner1.webp" class="rounded-2xl shadow-lg aspect-[3/4] object-cover" alt="Detail 1" />
        </div>
        <div class="space-y-4">
          <img src="/image/banner2.webp" class="rounded-2xl shadow-lg aspect-[3/4] object-cover" alt="Detail 2" />
        </div>
      </div>
    </div>
  </Section>

  <section class="py-24 bg-slate-900 text-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-20">
        <h2 class="text-3xl md:text-5xl font-bold mb-4 italic">Procurement Process</h2>
        <p class="text-slate-400 max-w-2xl mx-auto">A systematic 6-phase approach ensuring technical precision and reliable delivery.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-y-16 gap-x-12">
        {workflow.map((item, index) => (
          <div class="relative group">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 bg-blue-600 rounded-lg flex items-center justify-center group-hover:rotate-6 transition-transform">
                <item.icon className="w-6 h-6 text-white" />
              </div>
              <span class="text-sm font-mono text-blue-400 font-bold tracking-tighter">{item.phase}</span>
            </div>
            <h3 class="text-xl font-bold mb-4 text-white group-hover:text-blue-400 transition-colors">{item.title}</h3>
            <p class="text-slate-400 text-sm mb-6 leading-relaxed">{item.desc}</p>
            <ul class="space-y-2">
              {item.details.map(detail => (
                <li class="flex items-center gap-2 text-xs text-slate-500">
                  <ArrowRight className="w-3 h-3 text-blue-600" />
                  {detail}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 bg-blue-600 relative overflow-hidden">
    <div class="container mx-auto px-6 text-center relative z-10">
      <h2 class="text-4xl font-bold text-white mb-8">Ready to Optimize Your Production?</h2>
      <a href="/rfq" class="inline-flex items-center px-10 py-4 bg-white text-blue-700 font-bold rounded-full hover:bg-slate-100 transition-all shadow-xl hover:-translate-y-1">
        Start Your Project
        <ArrowRight className="ml-2 w-5 h-5" />
      </a>
    </div>
  </section>
</BaseLayout>