---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/ui/Section.astro';
import Card from '../components/ui/Card.astro';
import { Image } from 'astro:assets';
import { 
  Settings, Layers, Search, ArrowRight, Cpu, ChevronRight, Tool 
} from 'lucide-react';

// 复用 RFQ 的背景图
import rfqBgImg from '@assets/photo-1558618666-fcd25c85cd64.jpg';

// 分类配置
const machineCategories = [
  { id: 'paper-machine', name: 'Paper Machine', icon: Settings, color: 'text-blue-600' },
  { id: 'corrugating-roll', name: 'Corrugating Roll', icon: Layers, color: 'text-orange-500' }
];

// 临时占位图（建议找一张硬核的造纸设备图，这里先统一用一张高质量工业图）
const machinePlaceholder = 'https://images.unsplash.com/photo-1581092160562-40aa08e78837?q=80&w=800';

// 模拟数据
const paperMachines = [
  { name: 'Fourdrinier Paper Machine', specs: 'Width: 3200mm | 600m/min', img: machinePlaceholder, wpUrl: '#' },
  { name: 'Tissue Paper Line', specs: '15-30t/d | Energy Saving', img: machinePlaceholder, wpUrl: '#' },
  { name: 'Kraft Paper Machine', specs: 'Multi-cylinder | High Strength', img: machinePlaceholder, wpUrl: '#' },
  { name: 'Culture Paper System', specs: 'Automated Control | A4/A3', img: machinePlaceholder, wpUrl: '#' },
];

const corrugatingRolls = [
  { name: 'Tungsten Carbide Roll', specs: 'High Hardness | Long Life', img: machinePlaceholder, wpUrl: '#' },
  { name: 'Chrome Plated Roll', specs: 'Precision Flute | Anti-Corrosion', img: machinePlaceholder, wpUrl: '#' },
  { name: 'Peripheral Heating Roll', specs: 'Uniform Temp | High Speed', img: machinePlaceholder, wpUrl: '#' },
  { name: 'Custom Flute Profile', specs: 'A/B/C/E/F Flute Design', img: machinePlaceholder, wpUrl: '#' },
];
---

<BaseLayout title="Paper Machinery Solutions - Hejun Motors">
  <section class="relative h-[450px] md:h-[550px] flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <Image 
        src={rfqBgImg}
        alt="Paper machine technology"
        class="w-full h-full object-cover"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/95 via-blue-900/90 to-slate-900/85"></div>
    </div>

    <div class="container mx-auto relative z-10 px-4 text-center">
      <div class="inline-flex items-center px-4 py-2 mb-6 bg-blue-600/20 border border-blue-400/30 text-blue-300 text-xs font-bold rounded-full backdrop-blur-sm">
        <Settings className="w-4 h-4 mr-2" /> ADVANCED PAPERMAKING TECH
      </div>
      
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
        Industrial <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-orange-400 to-blue-400">Paper Machinery</span>
      </h1>

      <div class="relative max-w-2xl mx-auto mt-8">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
          <Search className="h-5 w-5 text-slate-400" />
        </div>
        <input 
          type="text" 
          placeholder="Search machines or rolls (e.g. Tungsten, 3200mm)..." 
          class="block w-full pl-12 pr-4 py-4 bg-white/10 border border-white/20 rounded-xl text-white placeholder-slate-400 backdrop-blur-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white/20 transition-all"
        />
        <button class="absolute right-2 top-2 bottom-2 px-6 bg-blue-600 hover:bg-blue-500 text-white rounded-lg font-bold transition-colors">
          Search
        </button>
      </div>
    </div>
  </section>

  <Section background="gray">
    <div class="flex flex-col lg:flex-row gap-10">
      
      <aside class="lg:w-72 flex-shrink-0">
        <div class="sticky top-28 space-y-3">
          <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4 px-2">Equipment Catalog</p>
          {machineCategories.map(cat => (
            <a 
              href={`#${cat.id}`} 
              class="flex items-center group px-4 py-3 bg-white border border-slate-200 rounded-xl hover:border-blue-500 hover:shadow-lg transition-all"
            >
              <cat.icon className={`w-5 h-5 mr-3 ${cat.color} group-hover:scale-110 transition-transform`} />
              <span class="text-sm font-bold text-slate-700 group-hover:text-blue-600">{cat.name}</span>
              <ChevronRight className="w-4 h-4 ml-auto text-slate-300 group-hover:text-blue-400" />
            </a>
          ))}
          
          <div class="mt-8 p-5 bg-slate-900 rounded-2xl text-white">
            <h4 class="font-bold mb-2 text-sm">Full Production Line?</h4>
            <p class="text-[11px] text-slate-400 mb-4 leading-relaxed">We provide turn-key solutions from pulping to finished paper reeling.</p>
            <a href="/rfq" class="text-[10px] font-black uppercase text-center bg-blue-600 py-2.5 rounded-lg block hover:bg-blue-500 transition-colors">Get Technical Proposal</a>
          </div>
        </div>
      </aside>

      <div class="flex-grow space-y-24">
        
        {/* --- Paper Machine Section --- */}
        <div id="paper-machine" class="scroll-mt-28">
          <div class="flex items-center gap-3 mb-8 border-b border-slate-200 pb-4">
            <div class="h-8 w-1.5 bg-blue-600 rounded-full"></div>
            <h2 class="text-2xl font-black text-slate-900 tracking-tight uppercase">Paper Machine Systems</h2>
          </div>
          
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
            {paperMachines.map(item => (
              <Card class="group p-0 overflow-hidden border-slate-200 hover:shadow-2xl transition-all flex flex-col bg-white">
                <div class="aspect-square overflow-hidden bg-slate-100">
                  <img src={item.img} alt={item.name} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                </div>
                <div class="p-4 flex flex-col flex-grow">
                  <h3 class="text-sm font-bold text-slate-900 mb-1 line-clamp-1">{item.name}</h3>
                  <div class="flex items-center mb-4">
                    <span class="px-1.5 py-0.5 bg-blue-50 text-blue-600 text-[10px] font-black rounded border border-blue-100 uppercase italic">Specs Verified</span>
                  </div>
                  <div class="mt-auto space-y-2">
                    <a href={item.wpUrl} target="_blank" class="w-full py-2 text-center border border-blue-600 text-blue-600 text-[10px] font-black rounded hover:bg-blue-600 hover:text-white transition-all block">VIEW DETAILS</a>
                    <a href="/rfq" class="w-full py-2 text-center bg-slate-800 text-white text-[10px] font-bold rounded hover:bg-slate-950 block transition-colors shadow-sm">INQUIRY</a>
                  </div>
                </div>
              </Card>
            ))}
          </div>
        </div>

        {/* --- Corrugating Roll Section --- */}
        <div id="corrugating-roll" class="scroll-mt-28">
          <div class="flex items-center gap-3 mb-8 border-b border-slate-200 pb-4">
            <div class="h-8 w-1.5 bg-orange-500 rounded-full"></div>
            <h2 class="text-2xl font-black text-slate-900 tracking-tight uppercase">Corrugating Rolls</h2>
          </div>
          
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
            {corrugatingRolls.map(item => (
              <Card class="group p-0 overflow-hidden border-slate-200 hover:shadow-2xl transition-all flex flex-col bg-white">
                <div class="aspect-square overflow-hidden bg-slate-100">
                  <img src={item.img} alt={item.name} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                </div>
                <div class="p-4 flex flex-col flex-grow">
                  <h3 class="text-sm font-bold text-slate-900 mb-1 line-clamp-1">{item.name}</h3>
                  <div class="flex items-center mb-4">
                    <span class="px-1.5 py-0.5 bg-orange-50 text-orange-600 text-[10px] font-black rounded border border-orange-100 uppercase italic">Precision Roll</span>
                  </div>
                  <div class="mt-auto space-y-2">
                    <a href={item.wpUrl} target="_blank" class="w-full py-2 text-center border border-orange-500 text-orange-500 text-[10px] font-black rounded hover:bg-orange-500 hover:text-white transition-all block">VIEW DETAILS</a>
                    <a href="/rfq" class="w-full py-2 text-center bg-slate-800 text-white text-[10px] font-bold rounded hover:bg-slate-950 block transition-colors shadow-sm">INQUIRY</a>
                  </div>
                </div>
              </Card>
            ))}
          </div>
        </div>

      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>