---
process.env.NODE_TLS_REJECT_UNAUTHORIZED = '0'; 
import BaseLayout from '../../layouts/BaseLayout.astro';
import { FileText, Zap, Target, ArrowRight } from 'lucide-react';

// 1. 动态路由生成 - 只抓取造纸机相关的产品
export async function getStaticPaths() {
  const API_URL = import.meta.env.WORDPRESS_API_URL;
  // 这里我们抓取所有文章，Astro 会根据路径自动匹配
  const query = `
    query GetAllSlugs {
      posts(first: 100) {
        nodes { slug }
      }
    }
  `;

  try {
    const response = await fetch(API_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ query }),
    });
    const { data } = await response.json();
    return data.posts.nodes.map((post) => ({
      params: { slug: post.slug },
    }));
  } catch (e) {
    console.error("Static paths fetch failed", e);
    return [];
  }
}

// 2. 获取具体产品数据
const { slug } = Astro.params;
const API_URL = import.meta.env.WORDPRESS_API_URL;

const query = `
  query GetProductDetail($slug: ID!) {
    post(id: $slug, idType: SLUG) {
      title
      content
      slug
      featuredImage {
        node { source_url: sourceUrl }
      }
      # 🎯 核心注入：对接 WPGraphQL Yoast SEO，把造纸机产品的 TDK 全打包带走
      seo {
        title
        metaDesc
        canonical
        opengraphImage {
          sourceUrl
        }
      }
    }
  }
`;

let product = null;
try {
  const response = await fetch(API_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ query, variables: { slug } }),
  });
  const { data } = await response.json();
  product = data.post;
} catch (e) {
  console.error("Product detail fetch failed", e);
}

if (!product) return Astro.redirect('/404');

// 3. 专属造纸机的侧边栏菜单
const paperCategories = [
  { id: 'paper-machine-paper-machine', name: 'Paper Machine', icon: FileText, color: 'text-slate-500' },
  { id: 'corrugating-roll', name: 'Corrugating Roll', icon: Target, color: 'text-orange-500' }
];
---

<BaseLayout 
  title={product.seo?.title || `${product.title} - Hejun Paper Machine`} 
  description={product.seo?.metaDesc || `Technical specifications for ${product.title}.`}
  ogImage={product.seo?.opengraphImage?.sourceUrl || product.featuredImage?.node?.source_url}
  canonicalUrl={product.seo?.canonical}
>
  <div class="max-w-[1600px] mx-auto grid grid-cols-1 lg:grid-cols-[320px_1fr] min-h-screen border-x border-slate-100">
    
    <aside class="bg-slate-50/80 border-r border-slate-200 p-6 lg:p-10 flex-shrink-0">
      <div class="sticky top-28">
        <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-6">Paper Machine Series</p>
        
        <nav class="space-y-3 mb-10">
          {paperCategories.map(cat => (
            <a href={`/paper-machine#${cat.id}`} class="flex items-center p-4 bg-white border border-slate-200 rounded-xl cursor-pointer transition-all group shadow-sm hover:border-blue-300">
              <cat.icon className={`w-4 h-4 mr-3 ${cat.color}`} />
              <span class="text-[12px] font-bold text-slate-700">{cat.name}</span>
            </a>
          ))}
        </nav>

        <div class="p-6 bg-[#1a1a1a] rounded-2xl text-white">
          <h4 class="text-[10px] font-black text-orange-400 mb-2 uppercase tracking-widest">Industry Support</h4>
          <p class="text-[11px] text-slate-400 leading-relaxed mb-6">Need custom configuration for your paper production line?</p>
          
          <button 
            onclick="window.openInquiryModal()" 
            class="w-full py-3 bg-orange-600 text-[11px] font-black text-center rounded-lg block cursor-pointer uppercase tracking-wider hover:bg-orange-500 transition-colors"
          >
            Request Quote
          </button>
        </div>
      </div>
    </aside>

    <main class="bg-white p-6 lg:p-16 overflow-hidden">
      <div class="max-w-5xl">
        
        <div class="flex flex-col xl:flex-row gap-12 mb-20 items-start">
          <div class="w-full xl:w-80 flex-shrink-0">
            <div class="aspect-square bg-white border border-slate-100 rounded-3xl p-8 flex items-center justify-center shadow-sm">
              <img 
                src={product.featuredImage?.node?.source_url || 'https://via.placeholder.com/800x800'} 
                alt={product.title}
                class="max-w-full max-h-full object-contain"
              />
            </div>
          </div>

          <div class="flex-grow pt-2">
            <div class="flex items-center gap-2 mb-4">
              <span class="w-2 h-2 bg-orange-600 rounded-full"></span>
              <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Paper Industry Solution</span>
            </div>
            
            <h1 class="text-3xl font-black text-slate-900 leading-tight mb-6 uppercase tracking-tight">
              {product.title}
            </h1>
            
            <div class="grid grid-cols-2 gap-4 mb-8">
              <div class="p-4 bg-slate-50 rounded-xl border border-slate-100">
                <p class="text-[9px] text-slate-400 uppercase font-bold tracking-wider">Durability</p>
                <p class="text-sm font-bold text-slate-900">Heavy Duty</p>
              </div>
              <div class="p-4 bg-slate-50 rounded-xl border border-slate-100">
                <p class="text-[9px] text-slate-400 uppercase font-bold tracking-wider">Application</p>
                <p class="text-sm font-bold text-slate-900">Industrial Grade</p>
              </div>
            </div>

            <div class="flex gap-4">
              <button 
                onclick="window.openInquiryModal()" 
                class="px-8 py-3.5 bg-slate-900 text-white text-[11px] font-black rounded-xl cursor-pointer flex items-center hover:bg-slate-800 transition-colors"
              >
                SEND INQUIRY <ArrowRight className="w-3 h-3 ml-2" />
              </button>
            </div>
          </div>
        </div>

        <div class="border-t border-slate-100 pt-16">
          <h2 class="text-base font-black text-slate-900 uppercase tracking-tighter mb-10 flex items-center">
            <span class="w-6 h-1 bg-orange-600 mr-4 rounded-full"></span> Technical Specifications
          </h2>
          
          <div class="prose prose-sm prose-slate max-w-none 
            prose-table:text-[13px] prose-table:border prose-table:border-slate-100
            prose-th:bg-slate-50 prose-th:text-slate-900 prose-th:p-4 prose-th:uppercase prose-th:tracking-tighter
            prose-td:p-4 prose-td:text-slate-600 prose-td:border-slate-50">
            <Fragment set:html={product.content} />
          </div>
        </div>

      </div>
    </main>
  </div>
</BaseLayout>

<style is:global>
  .prose table {
    width: 100% !important;
    border-collapse: collapse;
    margin: 2rem 0;
  }
  .prose th, .prose td {
    padding: 12px 16px;
    text-align: left;
    border: 1px solid #f1f5f9;
  }
  @media (max-width: 1024px) {
    .prose table {
      display: block;
      overflow-x: auto;
      white-space: nowrap;
    }
  }
</style>