---
// 🎯 核心修正 1：移除 SSR，明确指定为静态预渲染（或者直接删掉此行，Astro 默认即静态）
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import { 
  Calendar, ArrowLeft, Search, Newspaper, Zap, Target, Settings, ChevronRight 
} from 'lucide-react';
import { Image } from 'astro:assets';

// 2. 导入你的新背景图
import headerBgImg from '@assets/Efficiency-by-Design.webp';

// 🎯 核心修正 2：添加 getStaticPaths 函数，在打包时从 WordPress 捞出所有新闻的 slugs
export async function getStaticPaths() {
  const API_URL = import.meta.env.WORDPRESS_API_URL;
  const query = `
    query GetAllNewsSlugs {
      posts(where: {categoryName: "news"}, first: 100) {
        nodes { slug }
      }
    }
  `;

  try {
    const response = await fetch(API_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ query }),
    });
    const { data } = await response.json();
    return data.posts.nodes.map((post) => ({
      params: { slug: post.slug },
    }));
  } catch (e) {
    console.error("❌ News static paths fetch failed:", e);
    return [];
  }
}

// 1. 获取 URL 参数
const { slug } = Astro.params;
const API_URL = import.meta.env.WORDPRESS_API_URL;

let post = null;
let recentPosts = [];

try {
  // 同时获取当前文章详情（含 Yoast SEO 数据）和侧边栏需要的最近 3 篇文章
  const response = await fetch(API_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      query: `
        query GetPostAndSidebar($id: ID!) {
          post(id: $id, idType: SLUG) {
            title
            content
            date
            featuredImage {
              node {
                sourceUrl
              }
            }
            categories {
              nodes {
                name
              }
            }
            # 🎯 核心注入：捞出新闻本身的 Yoast SEO 数据
            seo {
              title
              metaDesc
              canonical
              opengraphImage {
                sourceUrl
              }
            }
          }
          posts(where: {categoryName: "news"}, first: 3) {
            nodes {
              title
              slug
              date
            }
          }
        }
      `,
      variables: { id: slug },
    }),
  });

  const json = await response.json();
  post = json.data?.post;
  recentPosts = json.data?.posts?.nodes || [];
} catch (error) {
  console.error("❌ News Detail API Error:", error);
}

// 如果没找到文章，重定向到 404
if (!post) {
  return Astro.redirect('/404');
}

// 格式化日期：May 15, 2026
const formattedDate = new Date(post.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const latestProducts = [
  { name: "IE5 Super Premium Motor", icon: Zap, href: "/motor#high-efficiency" },
  { name: "VRS Series Vector Motor", icon: Target, href: "/motor#vector-reluctance" },
  { name: "Corrugating Roll System", icon: Settings, href: "/paper-machine#corrugating-roll" }
];
---

<BaseLayout 
  title={post.seo?.title || `${post.title} - Hejun Electromechanical`} 
  description={post.seo?.metaDesc || `Read full industrial insights: ${post.title}.`}
  ogImage={post.seo?.opengraphImage?.sourceUrl || post.featuredImage?.node?.sourceUrl}
  canonicalUrl={post.seo?.canonical}
>
  <section class="relative py-16 md:py-24 bg-slate-900 overflow-hidden flex items-center">
    <div class="absolute inset-0">
      <Image src={headerBgImg} alt="News header background" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/90 via-slate-900/80 to-blue-900/60"></div>
    </div>
    
    <div class="container mx-auto px-6 relative z-10">
      <a href="/news" class="inline-flex items-center text-blue-400 hover:text-white transition-colors mb-6 text-sm font-bold uppercase tracking-widest group">
        <ArrowLeft className="w-4 h-4 mr-2 group-hover:-translate-x-1 transition-transform" /> Back to Insights
      </a>
      
      <div class="max-w-5xl">
        <h1 class="text-3xl md:text-5xl font-black text-white uppercase italic leading-tight">
          <Fragment set:html={post.title} />
        </h1>
      </div>
    </div>
  </section>

  <Section background="white">
    <div class="container mx-auto px-6">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">
        
        <div class="flex-grow">
          {post.featuredImage?.node?.sourceUrl && (
            <div class="mb-10 rounded-2xl overflow-hidden shadow-2xl border border-slate-100 max-w-3xl mx-auto">
              <img 
                src={post.featuredImage.node.sourceUrl} 
                alt={post.title}
                class="w-full h-auto object-cover max-h-[400px]" 
              />
            </div>
          )}

          <div class="flex items-center gap-6 mb-8 text-sm font-bold uppercase tracking-widest border-b border-slate-100 pb-6 max-w-4xl mx-auto">
            <div class="flex items-center gap-2 text-blue-600">
              <span class="px-3 py-1 bg-blue-50 rounded border border-blue-100">
                {post.categories?.nodes[0]?.name || 'Insights'}
              </span>
            </div>
            <div class="flex items-center gap-2 text-slate-400">
              <Calendar className="w-4 h-4" /> {formattedDate}
            </div>
          </div>

          <article class="prose prose-slate prose-lg max-w-4xl mx-auto 
            prose-headings:uppercase prose-headings:italic prose-headings:font-black prose-headings:text-slate-900
            prose-p:text-slate-600 prose-p:leading-relaxed prose-p:mb-6
            prose-strong:text-slate-900 prose-strong:font-bold
            prose-img:rounded-xl prose-img:shadow-lg prose-img:mx-auto prose-img:my-10 prose-img:w-full">
            <Fragment set:html={post.content} />
          </article>

          <div class="mt-16 p-8 bg-slate-900 rounded-2xl shadow-xl text-center relative overflow-hidden group max-w-4xl mx-auto">
            <div class="absolute inset-0 opacity-5 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
            <div class="relative z-10">
              <h4 class="text-2xl font-black text-white uppercase italic mb-4">Request Technical Consultation</h4>
              <p class="text-slate-400 mb-8 max-w-xl mx-auto italic">Our experts provide professional motor and drive system solutions tailored to your industrial requirements.</p>
              <a href="/rfq" class="inline-block px-10 py-4 bg-blue-600 text-white font-black uppercase tracking-widest hover:bg-blue-700 transition-all rounded-sm shadow-lg shadow-blue-200">
                Inquiry Now
              </a>
            </div>
          </div>
        </div>

        <aside class="lg:w-80 flex-shrink-0 space-y-8 mt-12 lg:mt-0">
          <div class="sticky top-28 space-y-8">
            
            <div class="bg-slate-50 p-2 rounded-2xl border border-slate-200 shadow-sm">
              <div class="relative">
                <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" />
                <input 
                  type="text" 
                  placeholder="Search updates..." 
                  class="w-full pl-10 pr-4 py-3 bg-white border-none rounded-xl text-sm focus:ring-2 focus:ring-blue-500 outline-none"
                />
              </div>
            </div>

            <nav class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
              <h4 class="text-xs font-black text-slate-900 uppercase tracking-widest mb-6 flex items-center gap-2 border-l-4 border-blue-600 pl-3">
                <Newspaper className="w-4 h-4" /> Recent Posts
              </h4>
              <div class="space-y-6">
                {recentPosts.map(rp => (
                  <a href={`/news/${rp.slug}/`} class="block group">
                    <p class="text-[10px] font-bold text-slate-400 mb-1 uppercase tracking-tighter">
                      {new Date(rp.date).toLocaleDateString('en-US')}
                    </p>
                    <p class="text-sm font-bold text-slate-800 group-hover:text-blue-600 line-clamp-2 transition-colors uppercase italic leading-tight">
                      <Fragment set:html={rp.title} />
                    </p>
                  </a>
                ))}
              </div>
            </nav>

            <div class="bg-[#012D46] rounded-2xl p-6 text-white shadow-xl relative overflow-hidden">
              <div class="absolute top-0 right-0 p-2 opacity-10">
                <Zap className="w-12 h-12 text-white" />
              </div>
              <h4 class="text-xs font-black text-blue-400 uppercase tracking-widest mb-6 relative z-10">Featured Tech</h4>
              <div class="space-y-3 relative z-10">
                {latestProducts.map(prod => (
                  <a href={prod.href} class="flex items-center justify-between p-3 rounded-xl bg-white/5 hover:bg-white/10 border border-white/10 transition-all group">
                    <div class="flex items-center gap-3">
                      <prod.icon className="w-4 h-4 text-blue-400" />
                      <span class="text-[11px] font-bold uppercase tracking-tight">{prod.name}</span>
                    </div>
                    <ChevronRight className="w-4 h-4 text-white/20 group-hover:text-white transition-colors" />
                  </a>
                ))}
              </div>
            </div>
            
          </div>
        </aside>
      </div>
    </div>
  </Section>
</BaseLayout>

<style is:global>
  /* 针对爬取的老图片定制的标准 */
  .prose img {
    display: block;
    margin: 3rem auto !important;
    border-radius: 0.75rem;
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
    
    /* 标准设置： */
    height: auto !important;
    /* 1. 如果图片够大，它会填满容器 (896px) */
    /* 2. 如果图片只有 600px，它会显示原大，不会被强行拉大导致糊掉 */
    width: auto !important; 
    max-width: 100% !important; 
    
    /* 3. 增强画质：针对老图的抗锯齿处理 */
    image-rendering: -webkit-optimize-contrast; 
  }

  /* 适配 WordPress 爬取时常见的 figure 标签 */
  .prose figure {
    margin: 2rem 0 !important;
    display: flex;
    flex-direction: column;
    align-items: center; /* 确保图和描述文字都居中 */
  }

  .prose figcaption {
    font-size: 0.875rem;
    font-style: italic;
    color: #64748b;
    margin-top: 0.75rem;
    text-align: center;
  }
</style>