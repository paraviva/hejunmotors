---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/ui/Section.astro';
import Card from '../components/ui/Card.astro';
import { Image } from 'astro:assets';
import { Zap, Target, Search, Cpu, ChevronRight } from 'lucide-react';
import rfqBgImg from '@assets/photo-1558618666-fcd25c85cd64.jpg';

const motorCategories = [
  { id: 'high-efficiency-motor', name: 'High-Efficiency Motor', icon: Zap, color: 'text-blue-500' },
  { id: 'vector-reluctance-motor', name: 'Vector Reluctance Motor', icon: Target, color: 'text-teal-500' }
];

const API_URL = import.meta.env.WORDPRESS_API_URL;

const query = `
query GetMotorProducts {
  highEfficiency: posts(where: {categoryName: "high-efficiency-motor"}, first: 20) {
    nodes { title slug excerpt featuredImage { node { sourceUrl } } }
  }
  vectorReluctance: posts(where: {categoryName: "vector-reluctance-motor"}, first: 20) {
    nodes { title slug excerpt featuredImage { node { sourceUrl } } }
  }
}
`;

let highEfficiencyMotors = [];
let vectorReluctanceMotors = [];

try {
  const response = await fetch(API_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ query }),
  });
  const { data } = await response.json();
  highEfficiencyMotors = data?.highEfficiency?.nodes || [];
  vectorReluctanceMotors = data?.vectorReluctance?.nodes || [];
} catch (e) {
  console.error('[motor.astro] API fetch failed:', e);
}

const placeholderImg = 'https://images.unsplash.com/photo-1537462715879-360eeb61a0ad?q=80&w=800';
---

<BaseLayout title="Motor Solutions - Hejun Motors">
  <section class="relative h-[450px] md:h-[550px] flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <Image 
        src={rfqBgImg}
        alt="Industrial motor technology"
        class="w-full h-full object-cover"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/95 via-blue-900/90 to-slate-900/85"></div>
    </div>

    <div class="container mx-auto relative z-10 px-4 text-center">
      <div class="inline-flex items-center px-4 py-2 mb-6 bg-blue-600/20 border border-blue-400/30 text-blue-300 text-sm font-bold rounded-full backdrop-blur-sm">
        <Cpu className="w-4 h-4 mr-2" /> NEXT-GEN DRIVE SYSTEMS
      </div>
      
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
        Precision <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-teal-400 to-blue-400">Motor Selection</span>
      </h1>

      <div class="relative max-w-2xl mx-auto mt-8">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
          <Search className="h-5 w-5 text-slate-400" />
        </div>
        <input 
          type="text" 
          placeholder="Enter model or specs (e.g. 11kW, IE5)..." 
          class="block w-full pl-12 pr-4 py-4 bg-white/10 border border-white/20 rounded-xl text-white placeholder-slate-400 backdrop-blur-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white/20 transition-all"
        />
        <button class="absolute right-2 top-2 bottom-2 px-6 bg-blue-600 hover:bg-blue-500 text-white rounded-lg font-bold transition-colors">
          Search
        </button>
      </div>
    </div>
  </section>

  <Section background="gray">
    <div class="flex flex-col lg:flex-row gap-10">
      
      <aside class="lg:w-72 flex-shrink-0">
        <div class="sticky top-28 space-y-3">
          <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4 px-2">Navigation</p>
          {motorCategories.map(cat => (
            <a 
              href={`#${cat.id}`} 
              class="flex items-center group px-4 py-3 bg-white border border-slate-200 rounded-xl hover:border-blue-500 hover:shadow-lg transition-all"
            >
              <cat.icon className={`w-5 h-5 mr-3 ${cat.color} group-hover:scale-110 transition-transform`} />
              <span class="text-sm font-bold text-slate-700 group-hover:text-blue-600">{cat.name}</span>
              <ChevronRight className="w-4 h-4 ml-auto text-slate-300 group-hover:text-blue-400" />
            </a>
          ))}
          
          <div class="mt-8 p-5 bg-slate-900 rounded-2xl text-white">
            <h4 class="font-bold mb-2 text-sm">Need Help?</h4>
            <p class="text-[11px] text-slate-400 mb-4 leading-relaxed">Our technical team provides professional motor selection services for free.</p>
            <a href="/rfq" class="text-[10px] font-black uppercase text-center bg-blue-600 py-2.5 rounded-lg block hover:bg-blue-500 transition-colors">Start Consultation</a>
          </div>
        </div>
      </aside>

      <div class="flex-grow space-y-24">

        {/* --- High-Efficiency Section --- */}
        <div id="high-efficiency-motor" class="scroll-mt-28">
          <div class="flex items-center gap-3 mb-8 border-b border-slate-200 pb-4">
            <div class="h-8 w-1.5 bg-blue-600 rounded-full"></div>
            <h2 class="text-2xl font-black text-slate-900 tracking-tight uppercase">High-Efficiency Motors</h2>
          </div>

          {highEfficiencyMotors.length === 0 ? (
            <p class="text-slate-400 text-sm">No products found.</p>
          ) : (
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
              {highEfficiencyMotors.map(motor => (
                <Card class="group p-0 overflow-hidden border-slate-200 hover:shadow-2xl transition-all flex flex-col bg-white">
                  <div class="aspect-square overflow-hidden bg-slate-100">
                    <img 
                      src={motor.featuredImage?.node?.sourceUrl || placeholderImg} 
                      alt={motor.title} 
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" 
                    />
                  </div>
                  <div class="p-4 flex flex-col flex-grow">
                    <h3 class="text-sm font-bold text-slate-900 mb-1 line-clamp-1">{motor.title}</h3>
                    <div class="flex items-center mb-4">
                      <span class="px-1.5 py-0.5 bg-blue-50 text-blue-600 text-[10px] font-black rounded border border-blue-100">IE5</span>
                    </div>
                    <div class="mt-auto space-y-2">
                      <a href={`/motor/${motor.slug}`} class="w-full py-2 text-center border border-blue-600 text-blue-600 text-[10px] font-black rounded hover:bg-blue-600 hover:text-white transition-all block">VIEW DETAILS</a>
                      <button onclick="window.openInquiryModal()" class="w-full py-2 text-center bg-slate-800 text-white text-[10px] font-bold rounded cursor-pointer block shadow-sm">INQUIRY</button>
                    </div>
                  </div>
                </Card>
              ))}
            </div>
          )}
        </div>

        {/* --- Vector Reluctance Section --- */}
        <div id="vector-reluctance-motor" class="scroll-mt-28">
          <div class="flex items-center gap-3 mb-8 border-b border-slate-200 pb-4">
            <div class="h-8 w-1.5 bg-teal-500 rounded-full"></div>
            <h2 class="text-2xl font-black text-slate-900 tracking-tight uppercase">Vector Reluctance Motors</h2>
          </div>

          {vectorReluctanceMotors.length === 0 ? (
            <p class="text-slate-400 text-sm">No products found.</p>
          ) : (
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
              {vectorReluctanceMotors.map(motor => (
                <Card class="group p-0 overflow-hidden border-slate-200 hover:shadow-2xl transition-all flex flex-col bg-white">
                  <div class="aspect-square overflow-hidden bg-slate-100">
                    <img 
                      src={motor.featuredImage?.node?.sourceUrl || placeholderImg} 
                      alt={motor.title} 
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" 
                    />
                  </div>
                  <div class="p-4 flex flex-col flex-grow">
                    <h3 class="text-sm font-bold text-slate-900 mb-1 line-clamp-1">{motor.title}</h3>
                    <div class="flex items-center mb-4">
                      <span class="px-1.5 py-0.5 bg-teal-50 text-teal-600 text-[10px] font-black rounded border border-teal-100">VR</span>
                    </div>
                    <div class="mt-auto space-y-2">
                      <a href={`/motor/${motor.slug}`} class="w-full py-2 text-center border border-teal-600 text-teal-600 text-[10px] font-black rounded hover:bg-teal-600 hover:text-white transition-all block">VIEW DETAILS</a>
                      <button onclick="window.openInquiryModal()" class="w-full py-2 text-center bg-slate-800 text-white text-[10px] font-bold rounded cursor-pointer block shadow-sm">INQUIRY</button>
                    </div>
                  </div>
                </Card>
              ))}
            </div>
          )}
        </div>

      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  html {
    scroll-behavior: smooth;
  }
  input::-webkit-search-cancel-button {
    display: none;
  }
</style>