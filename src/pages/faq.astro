---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/ui/Section.astro';
import { Image } from 'astro:assets';
import { 
  HelpCircle, Zap, Settings, Truck, ChevronDown, MessageSquare, ChevronRight, ArrowRight 
} from 'lucide-react';

// 复用 RFQ 的背景图
import rfqBgImg from '@assets/photo-1558618666-fcd25c85cd64.jpg';

const faqCategories = [
  { id: 'motor-faq', name: 'Motor Products', icon: Zap, color: 'text-blue-500' },
  { id: 'paper-faq', name: 'Paper Machine', icon: Settings, color: 'text-orange-500' },
  { id: 'service-faq', name: 'General Service', icon: Truck, color: 'text-emerald-500' }
];

const faqData = {
  'motor-faq': [
    { q: "What international certifications do your motors have?", a: "Our industrial motor series are certified with CE and ISO 9001. Explosion-proof motors comply with ATEX/IECEx standards, with efficiency ratings covering IE3 to IE5." },
    { q: "Can you customize motors for special voltage or frequency requirements?", a: "Yes. We support customization for 50Hz/60Hz, 220V-660V, and other voltage/frequency specifications, as well as mechanical adaptations like special protection, shaft extensions, or flanges." },
    { q: "What is the delivery time for motors?", a: "Standard models typically take 15-30 days. Customized products require 4-8 weeks based on technical complexity. Contact us for expedited production in urgent cases." }
  ],
  'paper-faq': [
    { q: "What are the main sections of a complete paper production line?", a: "It typically includes pulping system, headbox, wire section, press section, drying section, sizing/coating unit (optional), reeling/winding system, and automation control." },
    { q: "Do you provide installation and commissioning services?", a: "Yes. We offer global project execution services, including on-site installation guidance, equipment commissioning, process optimization, and operator training. Service scope is defined in the contract." },
    { q: "What about energy consumption and environmental performance?", a: "Our equipment features high-efficiency drives, heat recovery, and intelligent control, consuming less energy than industry averages. Wastewater recycling and exhaust treatment systems can be integrated to meet environmental regulations." }
  ],
  'service-faq': [
    { q: "What trade terms and payment methods are supported?", a: "We support common terms like FOB, CIF, EXW. Payments can be made via T/T or L/C, negotiable based on order value and cooperation history." },
    { q: "How can I get a quotation or technical proposal?", a: "Please provide detailed requirements (application scenario, technical parameters, capacity needs) via our website form, email, or customer service. We will respond within 24 hours." }
  ]
};
---

<BaseLayout title="FAQ Support - Hejun Motors">
  <section class="relative h-[400px] flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <Image src={rfqBgImg} alt="Support Center" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/95 via-blue-900/90 to-slate-900/85"></div>
    </div>
    <div class="container mx-auto relative z-10 px-4 text-center">
      <div class="inline-flex items-center px-4 py-2 mb-6 bg-blue-600/20 border border-blue-400/30 text-blue-300 text-xs font-bold rounded-full backdrop-blur-sm">
        <HelpCircle className="w-4 h-4 mr-2" /> KNOWLEDGE BASE
      </div>
      <h1 class="text-4xl md:text-6xl font-black text-white mb-4 uppercase">Technical <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400">Support & FAQ</span></h1>
      <p class="text-slate-400 max-w-2xl mx-auto">Quick answers to technical specifications, customization, and global logistics.</p>
    </div>
  </section>

  <Section background="gray">
    <div class="flex flex-col lg:flex-row gap-12">
      
      <aside class="lg:w-72 flex-shrink-0">
        <div class="sticky top-28 space-y-3">
          <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4 px-2">Support Categories</p>
          {faqCategories.map(cat => (
            <a 
              href={`#${cat.id}`} 
              class="flex items-center group px-4 py-4 bg-white border border-slate-200 rounded-xl hover:border-blue-500 hover:shadow-lg transition-all active:scale-95"
            >
              <cat.icon className={`w-5 h-5 mr-3 ${cat.color} group-hover:scale-110 transition-transform`} />
              <span class="text-sm font-bold text-slate-700 group-hover:text-blue-600">{cat.name}</span>
              <ChevronRight className="w-4 h-4 ml-auto text-slate-300 group-hover:text-blue-400" />
            </a>
          ))}
          
          <div class="mt-8 p-6 bg-slate-900 rounded-2xl text-white shadow-xl">
            <MessageSquare className="w-8 h-8 text-blue-500 mb-4" />
            <h4 class="font-bold mb-2">Direct Contact</h4>
            <p class="text-[11px] text-slate-400 mb-4 leading-relaxed">Can't find what you're looking for? Talk to our engineering team directly.</p>
            <a href="/rfq" class="text-xs font-black uppercase text-center bg-blue-600 py-3 rounded-lg block hover:bg-blue-500 transition-colors">Submit a Ticket</a>
          </div>
        </div>
      </aside>

      <div class="flex-grow space-y-20">
        
        {faqCategories.map(cat => (
          <div id={cat.id} class="scroll-mt-28">
            <div class="flex items-center gap-3 mb-8 border-b border-slate-200 pb-4">
              <div class={`h-8 w-1.5 rounded-full ${cat.id === 'motor-faq' ? 'bg-blue-600' : cat.id === 'paper-faq' ? 'bg-orange-500' : 'bg-emerald-500'}`}></div>
              <h2 class="text-2xl font-black text-slate-900 tracking-tight uppercase">{cat.name}</h2>
            </div>

            <div class="space-y-4">
              {faqData[cat.id].map(item => (
                <details class="group bg-white border border-slate-200 rounded-2xl overflow-hidden transition-all hover:border-blue-500 hover:shadow-md">
                  <summary class="flex items-center justify-between p-6 cursor-pointer list-none focus:outline-none">
                    <h3 class="text-base font-bold text-slate-800 pr-6">{item.q}</h3>
                    <div class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-slate-50 group-open:bg-blue-600 group-open:text-white transition-colors">
                      <ChevronDown className="w-5 h-5 group-open:rotate-180 transition-transform" />
                    </div>
                  </summary>
                  <div class="px-6 pb-6 pt-0 text-slate-600 leading-relaxed border-t border-slate-50 mt-2">
                    <div class="pt-4 flex gap-3">
                       <div class="w-1.5 h-1.5 rounded-full bg-blue-500 mt-2 shrink-0"></div>
                       <p class="italic text-sm">{item.a}</p>
                    </div>
                  </div>
                </details>
              ))}
            </div>
          </div>
        ))}

      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  html {
    scroll-behavior: smooth;
  }
  summary::-webkit-details-marker {
    display: none;
  }
  details[open] summary ~ * {
    animation: slideDown 0.3s ease-out;
  }
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>