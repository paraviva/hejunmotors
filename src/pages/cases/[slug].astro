---
// 🎯 核心修正 1：移除 SSR，明确指定为静态预渲染
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import { ArrowLeft, Search, Newspaper, Calendar, ChevronRight, Zap, Settings, Layers, Target } from 'lucide-react';
import { Image } from 'astro:assets';

// 复用带工业设计感的背景图
import headerBgImg from '@assets/Efficiency-by-Design.webp';

// 🎯 核心修正 2：添加 getStaticPaths 函数，在打包时从 WordPress 捞出所有案例的 slugs
export async function getStaticPaths() {
  const API_URL = import.meta.env.WORDPRESS_API_URL;
  const query = `
    query GetAllCaseSlugs {
      posts(first: 100) {
        nodes { slug }
      }
    }
  `;

  try {
    const response = await fetch(API_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ query }),
    });
    const { data } = await response.json();
    return data.posts.nodes.map((post) => ({
      params: { slug: post.slug },
    }));
  } catch (e) {
    console.error("❌ Case static paths fetch failed:", e);
    return [];
  }
}

const { slug } = Astro.params;
const API_URL = import.meta.env.WORDPRESS_API_URL;

let post = null;
let recentNews = [];

// 侧边栏专属：4个核心案例分类快捷入口配置（带上图标与颜色）
const caseCategories = [
  { id: 'motor', name: 'Motor projects', icon: Zap, color: 'text-blue-500', bg: 'hover:bg-blue-50' },
  { id: 'paper-machine', name: 'Paper machine projects', icon: Settings, color: 'text-orange-500', bg: 'hover:bg-orange-50' },
  { id: 'rollers', name: 'Rollers projects', icon: Layers, color: 'text-emerald-500', bg: 'hover:bg-emerald-50' },
  { id: 'vector', name: 'Vector reluctance motor projects', icon: Target, color: 'text-teal-500', bg: 'hover:bg-teal-50' }
];

try {
  // 抓取详情（含 Yoast SEO 数据）及侧边栏最近3条新闻
  const response = await fetch(API_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      query: `
        query GetCaseDetailWithSidebar($id: ID!) {
          post(id: $id, idType: SLUG) {
            title
            slug
            content
            date
            featuredImage { node { sourceUrl } }
            categories { nodes { name } }
            # 🎯 核心注入：对接 WPGraphQL Yoast SEO 插件，捞出完整的 TDK 和规范链接
            seo {
              title
              metaDesc
              canonical
              opengraphImage {
                sourceUrl
              }
            }
          }
          posts(where: {categoryName: "news"}, first: 3) {
            nodes {
              title
              slug
              date
            }
          }
        }
      `,
      variables: { id: slug },
    }),
  });

  const json = await response.json();
  post = json.data?.post;
  recentNews = json.data?.posts?.nodes || [];
} catch (error) {
  console.error("❌ Case Detail API Error:", error);
}

if (!post) {
  return Astro.redirect('/404');
}

const rawCategoryName = post.categories?.nodes[0]?.name || 'Success Stories';
const cleanCategoryName = rawCategoryName.replace(/ [Pp]rojects$/, '');
---

<BaseLayout 
  title={post.seo?.title || `${post.title} - Hejun Electromechanical`} 
  description={post.seo?.metaDesc} 
  ogImage={post.seo?.opengraphImage?.sourceUrl || post.featuredImage?.node?.sourceUrl}
  canonicalUrl={post.seo?.canonical}
>
  <section class="relative py-16 md:py-24 bg-slate-900 overflow-hidden flex items-center">
    <div class="absolute inset-0">
      <Image src={headerBgImg} alt="Case study header background" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/95 via-slate-900/85 to-blue-900/40"></div>
    </div>
    
    <div class="container mx-auto px-6 relative z-10">
      <a href="/cases" class="inline-flex items-center text-blue-400 hover:text-white transition-colors mb-6 text-sm font-bold uppercase tracking-widest group">
        <ArrowLeft className="w-4 h-4 mr-2 group-hover:-translate-x-1 transition-transform" /> Back to Cases
      </a>
      
      <div class="max-w-5xl">
        <div class="flex items-center gap-2 mb-4">
          <span class="px-3 py-1 bg-blue-600/30 border border-blue-500/30 text-blue-300 text-[10px] font-black uppercase tracking-[0.2em] rounded-full backdrop-blur-sm">
            {cleanCategoryName}
          </span>
        </div>
        <h1 class="text-3xl md:text-5xl font-black text-white uppercase italic leading-tight">
          <Fragment set:html={post.title} />
        </h1>
      </div>
    </div>
  </section>

  <Section background="white">
    <div class="container mx-auto px-6">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">
        
        <div class="flex-grow lg:max-w-[calc(100%-22rem)]">
          {post.featuredImage?.node?.sourceUrl && (
            <div class="mb-10 rounded-2xl overflow-hidden shadow-2xl border border-slate-100 w-full">
              <img src={post.featuredImage.node.sourceUrl} alt={post.title} class="w-full h-auto object-cover max-h-[480px]" />
            </div>
          )}

          <article class="prose prose-slate prose-lg max-w-none 
            prose-headings:uppercase prose-headings:italic prose-headings:font-black prose-headings:text-slate-900
            prose-p:text-slate-600 prose-p:leading-relaxed prose-p:mb-6
            prose-strong:text-slate-900 prose-strong:font-bold">
            <Fragment set:html={post.content} />
          </article>

          <div class="mt-16 p-10 bg-slate-900 rounded-3xl shadow-2xl text-center relative overflow-hidden group w-full">
            <div class="absolute inset-0 opacity-5 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
            <div class="relative z-10">
              <h4 class="text-2xl font-black text-white uppercase italic mb-3">Build a similar solution?</h4>
              <p class="text-slate-400 mb-8 max-w-xl mx-auto italic font-medium">Get an expert technical proposal and cost estimation tailored to your specific industrial line requirements.</p>
              <a href="/rfq" class="inline-block px-10 py-4 bg-blue-600 text-white font-black uppercase tracking-widest hover:bg-blue-700 transition-all rounded-sm shadow-xl shadow-blue-900/30">
                Get Technical Support
              </a>
            </div>
          </div>
        </div>

        <aside class="lg:w-80 flex-shrink-0 space-y-8 mt-12 lg:mt-0">
          <div class="sticky top-28 space-y-8">
            
            <div class="bg-slate-50 p-2 rounded-2xl border border-slate-200 shadow-sm">
              <div class="relative">
                <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" />
                <input 
                  type="text" 
                  placeholder="Search updates..." 
                  class="w-full pl-10 pr-4 py-3 bg-white border-none rounded-xl text-sm focus:ring-2 focus:ring-blue-500 outline-none"
                />
              </div>
            </div>

            <nav class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
              <h4 class="text-xs font-black text-slate-900 uppercase tracking-widest mb-4 flex items-center gap-2 border-l-4 border-blue-600 pl-3">
                Project Categories
              </h4>
              <div class="flex flex-col gap-2">
                {caseCategories.map(cat => (
                  <a 
                    href={`/cases#${cat.id}`} 
                    class={`flex items-center p-3 border border-slate-100 rounded-xl transition-all ${cat.bg} group active:scale-[0.98]`}
                  >
                    <cat.icon className={`w-4 h-4 mr-3 ${cat.color} group-hover:scale-110 transition-transform`} />
                    <span class="text-xs font-bold text-slate-600 group-hover:text-blue-600 uppercase italic transition-colors leading-none">
                      {cat.name}
                    </span>
                    <ChevronRight className="w-3 h-3 ml-auto text-slate-300 group-hover:text-blue-500 group-hover:translate-x-0.5 transition-all" />
                  </a>
                ))}
              </div>
            </nav>

            <nav class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
              <h4 class="text-xs font-black text-slate-900 uppercase tracking-widest mb-6 flex items-center gap-2 border-l-4 border-blue-600 pl-3">
                <Newspaper className="w-4 h-4" /> Recent Insights
              </h4>
              <div class="space-y-6">
                {recentNews.map(rn => (
                  <a href={`/news/${rn.slug}/`} class="block group">
                    <p class="text-[10px] font-bold text-slate-400 mb-1 uppercase">
                      {new Date(rn.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </p>
                    <p class="text-sm font-bold text-slate-800 group-hover:text-blue-600 line-clamp-2 uppercase italic leading-tight transition-colors">
                      <Fragment set:html={rn.title} />
                    </p>
                  </a>
                ))}
              </div>
            </nav>

          </div>
        </aside>

      </div>
    </div>
  </Section>
</BaseLayout>

<style is:global>
  .prose img {
    display: block;
    margin: 3rem auto !important;
    border-radius: 0.75rem;
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
    height: auto !important;
    width: auto !important; 
    max-width: 100% !important; 
    image-rendering: -webkit-optimize-contrast; 
  }
  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
  }
  .prose th, .prose td {
    border: 1px solid #e2e8f0;
    padding: 0.75rem;
    text-align: left;
  }
</style>